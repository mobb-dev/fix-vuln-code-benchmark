+  @Test
+  public void testCacheKeyIncludesProviderOptions() throws Exception {
+    ContextInternal ctx = (ContextInternal) vertx.getOrCreateContext();
+    SslContextManager helper = new SslContextManager(new JdkSSLEngineOptions());
+    SSLOptions options = new SSLOptions().setKeyCertOptions(Cert.SERVER_JKS.get()).setTrustOptions(Trust.SERVER_JKS.get());
+
+    SslContextProvider baseline = awaitFuture(helper.resolveSslContextProvider(options, "", ClientAuth.NONE, null, ctx));
+
+    assertSame(baseline, awaitFuture(helper.resolveSslContextProvider(options, "", ClientAuth.NONE, null, ctx)));
+    assertNotSame(baseline, awaitFuture(helper.resolveSslContextProvider(options, "HTTPS", ClientAuth.NONE, null, ctx)));
+    assertNotSame(baseline, awaitFuture(helper.resolveSslContextProvider(options, "", ClientAuth.REQUIRED, null, ctx)));
+    assertNotSame(baseline, awaitFuture(helper.resolveSslContextProvider(options, "", ClientAuth.NONE, Collections.singletonList("h2"), ctx)));
+
+    SSLOptions cipherOptions = new SSLOptions(options);
+    cipherOptions.addEnabledCipherSuite(createEngine(baseline).getEnabledCipherSuites()[0]);
+    assertNotSame(baseline, awaitFuture(helper.resolveSslContextProvider(cipherOptions, "", ClientAuth.NONE, null, ctx)));
+
+    SSLOptions protocolOptions = new SSLOptions(options);
+    protocolOptions.setEnabledSecureTransportProtocols(new LinkedHashSet<>(Collections.singletonList("TLSv1.3")));
+    assertNotSame(baseline, awaitFuture(helper.resolveSslContextProvider(protocolOptions, "", ClientAuth.NONE, null, ctx)));
+
+    SSLOptions crlOptions = new SSLOptions(options);
+    crlOptions.addCrlPath("tls/root-ca/crl.pem");
+    assertNotSame(baseline, awaitFuture(helper.resolveSslContextProvider(crlOptions, "", ClientAuth.NONE, null, ctx)));
+  }
