ons.getEnabledCipherSuites() != null ? new LinkedHashSet<>(options.getEnabledCipherSuites()) : null;\n317\t      this.enabledSecureTransportProtocols = options.getEnabledSecureTransportProtocols() != null ? new LinkedHashSet<>(options.getEnabledSecureTransportProtocols()) : null;\n318\t      this.hostnameVerificationAlgorithm = hostnameVerificationAlgorithm;\n319\t      this.clientAuth = clientAuth;\n320\t      this.applicationProtocols = applicationProtocols != null ? new ArrayList<>(applicationProtocols) : null;\n321\t    }\n322\t\n323\t    @Override\n324\t    public boolean equals(Object obj) {\n325\t      if (obj == this) {\n326\t        return true;\n327\t      }\n328\t      if (obj instanceof ProviderKey) {\n329\t        ProviderKey that = (ProviderKey) obj;\n330\t        return Objects.equals(keyCertOptions, that.keyCertOptions)\n331\t          && Objects.equals(trustOptions, that.trustOptions)\n332\t          && Objects.equals(crlValues, that.crlValues)\n333\t          && Objects.equals(crlPaths, that.crlPaths)\n334\t          && Objects.equals(enabledCipherSuites, that.enabledCipherSuites)\n335\t          && Objects.equals(enabledSecureTransportProtocols, that.enabledSecureTransportProtocols)\n336\t          && Objects.equals(hostnameVerificationAlgorithm, that.hostnameVerificationAlgorithm)\n337\t          && Objects.equals(clientAuth, that.clientAuth)\n338\t          && Objects.equals(applicationProtocols, that.applicationProtocols);\n339\t      }\n340\t      return false;\n341\t    }\n342\t\n343\t    @Override\n344\t    public int hashCode() {\n345\t      int hashCode = Objects.hashCode(keyCertOptions);\n346\t      hashCode = 31 * hashCode + Objects.hashCode(trustOptions);\n347\t      hashCode = 31 * hashCode + Objects.hashCode(crlValues);\n348\t      hashCode = 31 * hashCode + Objects.hashCode(crlPaths);\n349\t      hashCode = 31 * hashCode + Objects.hashCode(enabledCipherSuites);\n350\t      hashCode = 31 * hashCode + Objects.hashCode(enabledSecureTransportProtocols);"}]},"parent_tool_use_id":null,"session_id":"d3d74710-77b5-4ba6-968c-fab58a8b02b1","uuid":"1454626a-44e9-4eb1-8b4e-fcadc387a9cd","timestamp":"2026-06-30T14:42:08.246Z","tool_use_result":{"type":"text","file":{"filePath":"/work/vertx-core/src/main/java/io/vertx/core/internal/tls/SslContextManager.java","content":"\n  /**\n   * Cache key for a fully built {@link SslContextProvider}.\n   * <p>\n   * Unlike {@link ConfigKey} (which only identifies the key/trust/CRL material loaded into a {@link Config}),\n   * a provider also depends on the security parameters that govern certificate validation and negotiation:\n   * the hostname verification algorithm, the client authentication mode, the negotiated application protocols,\n   * the enabled cipher suites/secure transport protocols and the CRL paths. These must all take part in the\n   * cache key, otherwise two options sharing the same trust material but, for example, differing hostname\n   * verification settings would wrongly share a provider and bypass certificate validation (CWE-295).\n   */\n  private final static class ProviderKey {\n    private final KeyCertOptions keyCertOptions;\n    private final TrustOptions trustOptions;\n    private final List<Buffer> crlValues;\n    private final List<String> crlPaths;\n    private final Set<String> enabledCipherSuites;\n    private final Set<String> enabledSecureTransportProtocols;\n    private final String hostnameVerificationAlgorithm;\n    private final ClientAuth clientAuth;\n    private final List<String> applicationProtocols;\n\n    ProviderKey(SSLOptions options, String hostnameVerificationAlgorithm, ClientAuth clientAuth, List<String> applicationProtocols) {\n      this.keyCertOptions = options.getKeyCertOptions();\n      this.trustOptions = trustOptionsOf(options);\n      this.crlValues = options.getCrlValues() != null ? new ArrayList<>(options.getCrlValues()) : null;\n      this.crlPaths = options.getCrlPaths() != null ? new ArrayList<>(options.getCrlPaths()) : null;\n      this.enabledCipherSuites = options.getEnabledCipherSuites() != null ? new LinkedHashSet<>(options.getEnabledCipherSuites()) : null;\n      this.enabledSecureTransportProtocols = options.getEnabledSecureTransportProtocols() != null ? new LinkedHashSet<>(options.getEnabledSecureTransportProtocols()) : null;\n      this.hostnameVerificationAlgorithm = hostnameVerificationAlgorithm;\n      this.clientAuth = clientAuth;\n      this.applicationProtocols = applicationProtocols != null ? new ArrayList<>(applicationProtocols) : null;\n    }\n\n    @Override\n    public boolean equals(Object obj) {\n      if (obj == this) {\n        return true;\n      }\n      if (obj instanceof ProviderKey) {\n        ProviderKey that = (ProviderKey) obj;\n        return Objects.equals(keyCertOptions, that.keyCertOptions)\n          && Objects.equals(trustOptions, that.trustOptions)\n          && Objects.equals(crlValues, that.crlValues)\n          && Objects.equals(crlPaths, that.crlPaths)\n          && Objects.equals(enabledCipherSuites, that.enabledCipherSuites)\n          && Objects.equals(enabledSecureTransportProtocols, that.enabledSecureTransportProtocols)\n          && Objects.equals(hostnameVerificationAlgorithm, that.hostnameVerificationAlgorithm)\n          && Objects.equals(clientAuth, that.clientAuth)\n          && Objects.equals(applicationProtocols, that.applicationProtocols);\n      }\n      return false;\n    }\n\n    @Override\n    public int hashCode() {\n      int hashCode = Objects.hashCode(keyCertOptions);\n      hashCode = 31 * hashCode + Objects.hashCode(trustOptions);\n      hashCode = 31 * hashCode + Objects.hashCode(crlValues);\n      hashCode = 31 * hashCode + Objects.hashCode(crlPaths);\n      hashCode = 31 * hashCode + Objects.hashCode(enabledCipherSuites);\n      hashCode = 31 * hashCode + Objects.hashCode(enabledSecureTransportProtocols);","numLines":62,"startLine":289,"totalLines":373}}}
