texts[idx] = context;\n132\t    }\n133\t    return sslContexts[idx];\n134\t  }\n135\t\n136\t  public SslContext sslServerContext(boolean useAlpn) {\n137\t    try {\n138\t      return sslContext(null, useAlpn, true);\n139\t    } catch (Exception e) {\n140\t      throw new VertxException(e);\n141\t    }\n142\t  }\n143\t\n144\t  /**\n145\t   * Server name {@link AsyncMapping} for {@link SniHandler}, mapping happens on a Vert.x worker thread.\n146\t   *\n147\t   * @return the {@link AsyncMapping}\n148\t   */\n149\t  public AsyncMapping<? super String, ? extends SslContext> serverNameMapping(Executor workerPool, boolean useAlpn) {\n150\t    return (AsyncMapping<String, SslContext>) (serverName, promise) -> {\n151\t      workerPool.execute(() -> {\n152\t        SslContext sslContext;\n153\t        try {\n154\t          sslContext = sslContext(serverName, useAlpn, true);\n155\t        } catch (Exception e) {\n156\t          promise.setFailure(e);\n157\t          return;\n158\t        }\n159\t        promise.setSuccess(sslContext);\n160\t      });\n161\t      return promise;\n162\t    };\n163\t  }\n164\t\n165\t  public VertxSslContext createContext(boolean server, boolean useAlpn) {\n166\t    return createContext(server, defaultKeyManagerFactory(), defaultTrustManagers(), null, useAlpn);\n167\t  }\n168\t\n169\t  public VertxSslContext createClientContext(\n170\t    KeyManagerFactory keyManagerFactory,\n171\t    TrustManager[] trustManagers,\n172\t    String serverName,\n173\t    boolean useAlpn) {\n174\t    try {\n175\t      SslContextFactory factory = provider.get()\n176\t        .useAlpn(useAlpn)\n177\t        .forClient(true)\n178\t        .enabledCipherSuites(enabledCipherSuites)\n179\t        .applicationProtocols(applicationProtocols);\n180\t      if (keyManagerFactory != null) {\n181\t        factory.keyMananagerFactory(keyManagerFactory);\n182\t      }\n183\t      if (trustManagers != null) {\n184\t        TrustManagerFactory tmf = buildVertxTrustManagerFactory(trustManagers);\n185\t        factory.trustManagerFactory(tmf);\n186\t      }\n187\t      SslContext context = factory.create();\n188\t      return new VertxSslContext(context) {\n189\t        @Override\n190\t        protected void initEngine(SSLEngine engine) {\n191\t          configureEngine(engine, enabledProtocols, serverName, true);\n192\t        }\n193\t      };\n194\t    } catch (Exception e) {\n195\t      throw new VertxException(e);\n196\t    }\n197\t  }\n198\t\n199\t  public VertxSslContext createServerContext(KeyManagerFactory keyManagerFactory,\n200\t                                        TrustManager[] trustManagers,\n201\t                                        String serverName,\n202\t                                        boolean useAlpn) {\n203\t    try {\n204\t      SslContextFactory factory = provider.get()\n205\t        .useAlpn(useAlpn)\n206\t        .forClient(false)\n207\t        .enabledCipherSuites(enabledCipherSuites)\n208\t        .applicationProtocols(applicationProtocols);\n209\t      factory.clientAuth(SslContextManager.CLIENT_AUTH_MAPPING.get(clientAuth));\n210\t      if (serverName != null) {\n211\t        factory.serverName(serverName);\n212\t      }\n213\t      if (keyManagerFactory != null) {\n214\t        factory.keyMananagerFactory(keyManagerFactory);\n215\t      }\n216\t      if (trustManagers != null) {\n217\t        TrustManagerFactory tmf = buildVertxTrustManagerFactory(trustManagers);\n218\t        factory.trustManagerFactory(tmf);\n219\t      }\n220\t      SslContext context = factory.create();\n221\t      return new VertxSslContext(context) {\n222\t        @Override\n223\t        protected void initEngine(SSLEngine engine) {\n224\t          configureEngine(engine, enabledProtocols, serverName, false);\n225\t        }\n226\t      };\n227\t    } catch (Exception e) {\n228\t      throw new VertxException(e);\n229\t    }\n230\t  }\n231\t\n232\t  public TrustManager[] defaultTrustManagers() {\n233\t    return trustManagerFactory 