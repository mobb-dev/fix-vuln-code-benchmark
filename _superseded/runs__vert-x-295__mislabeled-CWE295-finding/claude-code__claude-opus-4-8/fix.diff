+      this.hostnameVerificationAlgorithm = hostnameVerificationAlgorithm;
+      this.clientAuth = clientAuth;
+      this.applicationProtocols = applicationProtocols != null ? new ArrayList<>(applicationProtocols) : null;
+    }
