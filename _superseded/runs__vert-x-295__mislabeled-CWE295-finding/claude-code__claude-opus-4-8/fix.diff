+      this.crlPaths = options.getCrlPaths() != null ? new ArrayList<>(options.getCrlPaths()) : null;
+      this.enabledCipherSuites = options.getEnabledCipherSuites() != null ? new LinkedHashSet<>(options.getEnabledCipherSuites()) : null;
