# Copy this file to .env and paste your Claude subscription token.
# Get the token by running: claude setup-token
#
# Docker reads this with --env-file, so use a raw KEY=VALUE line:
# no quotes, no "export", no spaces around the "=".
CLAUDE_CODE_OAUTH_TOKEN=

# Optional: MiniMax key for the swappable claude-code lane (CLAUDE_BACKEND=minimax).
# Get one at platform.minimax.io. Read by the runner only — it is passed to the agent
# container as ANTHROPIC_AUTH_TOKEN, never alongside the Claude token above.
MINIMAX_API_KEY=
