.NONE, io.netty.handler.ssl.ClientAuth.NONE);\n46\t  }\n47\t\n48\t  private final Supplier<SslContextFactory> supplier;\n49\t  private final boolean useWorkerPool;\n50\t  private final Map<ConfigKey, Future<Config>> configMap;\n51\t  private final Map<ConfigKey, Future<SslContextProvider>> sslContextProviderMap;\n52\t\n53\t  public SslContextManager(SSLEngineOptions sslEngineOptions, int cacheMaxSize) {\n54\t    this.configMap = new LruCache<>(cacheMaxSize);\n55\t    this.sslContextProviderMap = new LruCache<>(cacheMaxSize);\n56\t    this.supplier = sslEngineOptions::sslContextFactory;\n57\t    this.useWorkerPool = sslEngineOptions.getUseWorkerThread();\n58\t  }\n59\t\n60\t  /**\n61\t   * Resolve the ssl engine options to use for properly running the configured options.\n62\t   */\n63\t  public static SSLEngineOptions resolveEngineOptions(SSLEngineOptions engineOptions, boolean useAlpn) {\n64\t    if (engineOptions == null) {\n65\t      if (useAlpn) {\n66\t        if (JdkSSLEngineOptions.isAlpnAvailable()) {\n67\t          engineOptions = new JdkSSLEngineOptions();\n68\t        } else if (OpenSSLEngineOptions.isAlpnAvailable()) {\n69\t          engineOptions = new OpenSSLEngineOptions();\n70\t        }\n71\t      }\n72\t    }\n73\t    if (engineOptions == null) {\n74\t      engineOptions = new JdkSSLEngineOptions();\n75\t    } else if (engineOptions instanceof OpenSSLEngineOptions) {\n76\t      if (!OpenSsl.isAvailable()) {\n77\t        VertxException ex = new VertxException(\"OpenSSL is not available\");\n78\t        Throwable cause = OpenSsl.unavailabilityCause();\n79\t        if (cause != null) {\n80\t          ex.initCause(cause);\n81\t        }\n82\t        throw ex;\n83\t      }\n84\t    }\n85\t\n86\t    if (useAlpn) {\n87\t      if (engineOptions instanceof JdkSSLEngineOptions) {\n88\t        if (!JdkSSLEngineOptions.isAlpnAvailable()) {\n89\t          throw new VertxException(\"ALPN not available for JDK SSL/TLS engine\");\n90\t        }\n91\t      }\n92\t      if (engineOptions instanceof OpenSSLEngineOptions) {\n93\t        if (!OpenSSLEngineOptions.isAlpnAvailable()) {\n94\t          throw new VertxException(\"ALPN is not available for OpenSSL SSL/TLS engine\");\n95\t        }\n96\t      }\n97\t    }\n98\t    return engineOptions;\n99\t  }\n100\t\n101\t  public synchronized int sniEntrySize() {\n102\t    int size = 0;\n103\t    for (Future<SslContextProvider> fut : sslContextProviderMap.values()) {\n104\t      SslContextProvider result = fut.result();\n105\t      if (result != null) {\n106\t        size += result.sniEntrySize();\n107\t      }\n108\t    }\n109\t    return size;\n110\t  }\n111\t\n112\t  public SslContextManager(SSLEngineOptions sslEngineOptions) {\n113\t    this(sslEngineOptions, 256);\n114\t  }\n115\t\n116\t  public Future<SslContextProvider> resolveSslContextProvider(SSLOptions options, String endpointIdentificationAlgorithm, ClientAuth clientAuth, List<String> applicationProtocols, ContextInternal ctx) {\n117\t    return resolveSslContextProvider(options, endpointIdentificationAlgorithm, clientAuth, applicationProtocols, false, ctx);\n118\t  }\n119\t\n120\t  public Future<SslContextProvider> resolveSslContextProvider(SSLOptions options, String hostnameVerificationAlgorithm, ClientAuth clientAuth, List<String> applicationProtocols, boolean force, ContextInternal ctx) {\n121\t    Promise<SslContextProvider> promise;\n122\t    ConfigKey k = new ConfigKey(options);\n123\t    synchronized (this) {\n124\t      if (force) {\n125\t        sslContextProviderMap.remove(k);\n126\t      } else {\n127\t        Future<SslContextProvider> v = sslContextProviderMap.get(k);\n128\t        if (v != null) {\n129\t          return v;\n130\t        }\n131\t      }\n132\t      promise = Promise.promise();\n133\t      sslContextProviderMap.put(k, promise.future());\n134\t    }\n135\t    buildSslContextProvider(options, hostnameVerificationAlgorithm, clientAuth, applicationProtocols, force, ctx)\n136\t      .onComplete(promise);\n137\t    return promise.future();\n138\t  }\n139\t\n140\t  /**\n141\t   * Initialize the helper, this loads and validates the configuration.\n142\t   *\n143\t   * @param ctx the context\n144\t   * @return a future resolved when the helper is initialized\n145\t   */\n146\t  public Future<SslContextProvider> buildSslContextProvider(SSLOptions sslOptions,\n147\t                                                     String hostnameVerificationAlgorithm,\n148\t                                                     ClientAuth clientAuth,\n149\t                                                     List<String> applicationProtocols,\n150\t                                                     boolean force,\n151\t                                                     ContextInternal ctx) {\n152\t    return buildConfig(sslOptions, force, ctx)\n153\t      .map(config -> buildSslContextProvider(sslOptions, hostnameVerificationAlgorithm, supplier, clientAuth, applicationProtocols, config));\n154\t  }\n155\t\n156\t  private SslContextProvider buildSslContextProvider(SSLOptions sslOptions, String hostnameVerificationAlgorithm, Supplier<SslContextFactory> supplier, ClientAuth clientAuth, List<String> applicationProtocols, Config config) {\n157\t    if (clientAuth == null && hostnameVerificationAlgorithm == null) {\n158\t      throw new VertxException(\"Missing hostname verification algorithm: you must set TCP client options host name\" +\n159\t        \" verification algorithm\");\n160\t    }\n161\t    return new SslContextProvider(\n162\t      useWorkerPool,\n163\t      clientAuth,\n164\t      hostnameVerificationAlgorithm,\n165\t      applicationProtocols,\n166\t      sslOptions.getEnabledCipherSuites(),\n167\t      sslOptions.getEnabledSecureTransportProtocols(),\n168\t      config.keyManagerFactory,\n169\t      config.keyManagerFactoryMapper,\n170\t      config.trustManagerFactory,\n171\t      config.trustManagerMapper,\n172\t      config.crls,\n173\t      supplier);\n174\t  }\n175\t\n176\t  private static TrustOptions trustOptionsOf(SSLOptions sslOptions) {\n177\t    if (sslOptions instanceof ClientSSLOptions) {\n178\t      ClientSSLOptions clientSSLOptions = (ClientSSLOptions) sslOptions;\n179\t      if (clientSSLOptions.isTrustAll()) {\n180\t        return TrustAllOptions.INSTANCE;\n181\t      }\n182\t    }\n183\t    return sslOptions.getTrustOptions();\n184\t  }\n185\t\n186\t  private Future<Config> buildConfig(SSLOptions sslOptions, boolean force, ContextInternal ctx) {\n187\t    if (trustOptionsOf(sslOptions) == null && sslOptions.getKeyCertOptions() == null) {\n188\t      return ctx.succeededFuture(NULL_CONFIG);\n189\t    }\n190\t    Promise<Config> promise;\n191\t    ConfigKey k = new ConfigKey(sslOptions);\n192\t    synchronized (this) {\n193\t      if (force) {\n194\t        configMap.remove(k);\n195\t      } else {\n196\t        Future<Config> fut = configMap.get(k);\n197\t        if (fut != null) {\n198\t          return fut;\n199\t        }\n200\t      }\n201\t      promise = Promise.promise();\n202\t      configMap.put(k, promise.future());\n203\t    }\n204\t    ctx.executeBlockingInternal(() -> {\n205\t      KeyManagerFactory keyManagerFactory = null;\n206\t      Function<String, KeyManagerFactory> keyManagerFactoryMapper = null;\n207\t      TrustManagerFactory trustManagerFactory = null;\n208\t      Function<String, TrustManager[]> trustManagerMapper = null;\n209\t      List<CRL> crls = new ArrayList<>();\n210\t      if (sslOptions.getKeyCertOptions() != null) {\n211\t        keyManagerFactory = sslOptions.getKeyCertOptions().getKeyManagerFactory(ctx.owner());\n212\t        keyManagerFactoryMapper = sslOptions.getKeyCertOptions().keyManagerFactoryMapper(ctx.owner());\n213\t      }\n214\t      TrustOptions trustOptions = trustOptionsOf(sslOptions);\n215\t      if (trustOptions != null) {\n216\t        trustManagerFactory = trustOptions.getTrustManagerFactory(ctx.owner());\n217\t        trustManagerMapper = trustOptions.trustManagerMapper(ctx.owner());\n218\t      }\n219\t      List<Buffer> tmp = new ArrayList<>();\n220\t      if (sslOptions.getCrlPaths() != null) {\n221\t        tmp.addAll(sslOptions.getCrlPaths()\n222\t          .stream()\n223\t          .map(path -> ctx.owner().fileResolver().resolve(path).getAbsolutePath())\n224\t          .map(ctx.owner().fileSystem()::readFileBlocking)\n225\t          .collect(Collectors.toList()));\n226\t      }\n227\t      if (sslOptions.getCrlValues() != null) {\n228\t        tmp.addAll(sslOptions.getCrlValues());\n229\t      }\n230\t      CertificateFactory certificatefactory = CertificateFactory.getInstance(\"X.509\");\n231\t      for (Buffer crlValue : tmp) {\n232\t        crls.addAll(certificatefactory.generateCRLs(new ByteArrayInputStream(crlValue.getBytes())));\n233\t      }\n234\t      return new Config(keyManagerFactory, trustManagerFactory, keyManagerFactoryMapper, trustManagerMapper, crls);\n235\t    }).onComplete(promise);\n236\t    return promise.future();\n237\t  }\n238\t\n239\t  private static class LruCache<K, V> extends LinkedHashMap<K, V> {\n240\t\n241\t    private final int maxSize;\n242\t\n243\t    public LruCache(int maxSize) {\n244\t      if (maxSize < 1) {\n245\t        throw new UnsupportedOperationException();\n246\t      }\n247\t      this.maxSize = maxSize;\n248\t    }\n249\t\n250\t    @Override\n251\t    protected boolean removeEldestEntry(Map.Entry<K, V> eldest) {\n252\t      return size() > maxSize;\n253\t    }\n254\t  }\n255\t\n256\t  private final static class ConfigKey {\n257\t    private final KeyCertOptions keyCertOptions;\n258\t    private final TrustOptions trustOptions;\n259\t    private final List<Buffer> crlValues;\n260\t    public ConfigKey(SSLOptions options) {\n261\t      this(options.getKeyCertOptions(), trustOptionsOf(options), options.getCrlValues());\n262\t    }\n263\t    public ConfigKey(KeyCertOptions keyCertOptions, TrustOptions trustOptions, List<Buffer> crlValues) {\n264\t      this.keyCertOptions = keyCertOptions;\n265\t      this.trustOptions = trustOptions;\n266\t      this.crlValues = crlValues != null ? new ArrayList<>(crlValues) : null;\n267\t    }\n268\t\n269\t    @Override\n270\t    public boolean equals(Object obj) {\n271\t      if (obj == this) {\n272\t        return true;\n273\t      }\n274\t      if (obj instanceof ConfigKey) {\n275\t        ConfigKey that = (ConfigKey) obj;\n276\t        return Objects.equals(keyCertOptions, that.keyCertOptions) && Objects.equals(trustOptions, that.trustOptions) && Objects.equals(crlValues, that.crlValues);\n277\t      }\n278\t      return false;\n279\t    }\n280\t\n281\t    @Override\n282\t    public int hashCode() {\n283\t      int hashCode = Objects.hashCode(keyCertOptions);\n284\t      hashCode = 31 * hashCode + Objects.hashCode(trustOptions);\n285\t      hashCode = 31 * hashCode + Objects.hashCode(crlValues);\n286\t      return hashCode;\n287\t    }\n288\t  }\n289\t\n290\t  private final static class Config {\n291\t    private final KeyManagerFactory keyManagerFactory;\n292\t    private final TrustManagerFactory trustManagerFactory;\n293\t    private final Function<String, KeyManagerFactory> keyManagerFactoryMapper;\n294\t    private final Function<String, TrustManager[]> trustManagerMapper;\n295\t    private final List<CRL> crls;\n296\t    public Config(KeyManagerFactory keyManagerFactory, TrustManagerFactory trustManagerFactory, Function<String, KeyManagerFactory> keyManagerFactoryMapper, Function<String, TrustManager[]> trustManagerMapper, List<CRL> crls) {\n297\t      this.keyManagerFactory = keyManagerFactory;\n298\t      this.trustManagerFactory = trustManagerFactory;\n299\t      this.keyManagerFactoryMapper = keyManagerFactoryMapper;\n300\t      this.trustManagerMapper = trustManagerMapper;\n301\t      this.crls = crls;\n302\t    }\n303\t  }\n304\t}\n305\t"}]},"parent_tool_use_id":"toolu_01DvUQW8tGBcFYHnr4ckxVkC","session_id":"a970fde1-5355-4597-a279-877b7b49436b","uuid":"3e29d216-5b0a-46e6-a5d2-