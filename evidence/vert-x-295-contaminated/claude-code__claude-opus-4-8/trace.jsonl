t\n50\t  public SslHandler createClientSslHandler(SocketAddress peerAddress, String serverName, boolean useAlpn, long sslHandshakeTimeout, TimeUnit sslHandshakeTimeoutUnit) {\n51\t    SslContext sslContext = sslContextProvider.sslClientContext(serverName, useAlpn);\n52\t    SslHandler sslHandler;\n53\t    Executor delegatedTaskExec = sslContextProvider.useWorkerPool() ? workerPool : ImmediateExecutor.INSTANCE;\n54\t    if (peerAddress != null && peerAddress.isInetSocket()) {\n55\t      sslHandler = sslContext.newHandler(ByteBufAllocator.DEFAULT, peerAddress.host(), peerAddress.port(), delegatedTaskExec);\n56\t    } else {\n57\t      sslHandler = sslContext.newHandler(ByteBufAllocator.DEFAULT, delegatedTaskExec);\n58\t    }\n59\t    sslHandler.setHandshakeTimeout(sslHandshakeTimeout, sslHandshakeTimeoutUnit);\n60\t    return sslHandler;\n61\t  }\n62\t\n63\t  public ChannelHandler createServerHandler(boolean useAlpn, long sslHandshakeTimeout, TimeUnit sslHandshakeTimeoutUnit, HostAndPort remoteAddress) {\n64\t    if (sni) {\n65\t      return createSniHandler(useAlpn, sslHandshakeTimeout, sslHandshakeTimeoutUnit, remoteAddress);\n66\t    } else {\n67\t      return createServerSslHandler(useAlpn, sslHandshakeTimeout, sslHandshakeTimeoutUnit, remoteAddress);\n68\t    }\n69\t  }\n70\t\n71\t  private SslHandler createServerSslHandler(boolean useAlpn, long sslHandshakeTimeout, TimeUnit sslHandshakeTimeoutUnit, HostAndPort remoteAddress) {\n72\t    SslContext sslContext = sslContextProvider.sslServerContext(useAlpn);\n73\t    Executor delegatedTaskExec = sslContextProvider.useWorkerPool() ? workerPool : ImmediateExecutor.INSTANCE;\n74\t    SslHandler sslHandler;\n75\t    if (remoteAddress != null) {\n76\t      sslHandler = sslContext.newHandler(ByteBufAllocator.DEFAULT, remoteAddress.host(), remoteAddress.port(), delegatedTaskExec);\n77\t    } else {\n78\t      sslHandler = sslContext.newHandler(ByteBufAllocator.DEFAULT, delegatedTaskExec);\n79\t    }\n80\t    sslHandler.set