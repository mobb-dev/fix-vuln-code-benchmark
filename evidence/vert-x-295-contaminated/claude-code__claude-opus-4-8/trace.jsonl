pointIdentificationAlgorithm;\n50\t  private final KeyManagerFactory keyManagerFactory;\n51\t  private final TrustManagerFactory trustManagerFactory;\n52\t  private final Function<String, KeyManagerFactory> keyManagerFactoryMapper;\n53\t  private final Function<String, TrustManager[]> trustManagerMapper;\n54\t\n55\t  private final SslContext[] sslContexts = new SslContext[2];\n56\t  private final Map<String, SslContext>[] sslContextMaps = new Map[]{\n57\t    new ConcurrentHashMap<>(), new ConcurrentHashMap<>()\n58\t  };\n59\t\n60\t  public SslContextProvider(boolean useWorkerPool,\n61\t                            ClientAuth clientAuth,\n62\t                            String endpointIdentificationAlgorithm,\n63\t                            List<String> applicationProtocols,\n64\t                            Set<String> enabledCipherSuites,\n65\t                            Set<String> enabledProtocols,\n66\t                            KeyManagerFactory keyManagerFactory,\n67\t                            Function<String, KeyManagerFactory> keyManagerFactoryMapper,\n68\t                            TrustManagerFactory trustManagerFactory,\n69\t                            Function<String, TrustManager[]> trustManagerMapper,\n70\t                            List<CRL> crls,\n71\t                            Supplier<SslContextFactory> provider) {\n72\t    this.useWorkerPool = useWorkerPool;\n73\t    this.provider = provider;\n74\t    this.clientAuth = clientAuth;\n75\t    this.endpointIdentificationAlgorithm = endpointIdentificationAlgorithm;\n76\t    this.applicationProtocols = applicationProtocols;\n77\t    this.enabledCipherSuites = new HashSet<>(enabledCipherSuites);\n78\t    this.enabledProtocols = enabledProtocols;\n79\t    this.keyManagerFactory = keyManagerFactory;\n80\t    this.trustManagerFactory = trustManagerFactory;\n81\t    this.keyManagerFactoryMapper = keyManagerFactoryMapper;\n82\t    this.trustManagerMapper = trustManagerMapper;\n83\t    this.crls = crls;\n84\t  }\n85\t\n86\t  public boolean useWorkerPool() {\n87\t    return useWorkerPool;\n88\t  }\n89\t\n90\t  public int sniEntrySize() {\n91\t    return sslContextMaps[0].size() + sslContextMaps[1].size();\n92\t  }\n93\t\n94\t  public VertxSslContext createContext(boolean server,\n95\t                                       KeyManagerFactory keyManagerFactory,\n96\t                                       TrustManager[] trustManagers,\n97\t                                       String serverName,\n98\t                                       boolean useAlpn) {\n99\t    if (keyManagerFactory == null) {\n100\t      keyManagerFactory = defaultKeyManagerFactory();\n101\t    }\n102\t    if (trustManagers == null) {\n103\t      trustManagers = defaultTrustManagers();\n104\t    }\n105\t    if (server) {\n106\t      return createServerContext(keyManagerFactory, trustManagers, serverName, useAlpn);\n107\t    } else {\n108\t      return createClientContext(keyManagerFactory, trustManagers, serverName, useAlpn);\n109\t    }\n110\t  }\n111\t\n112\t  public SslContext sslClientContext(String serverName, boolean useAlpn) {\n113\t    try {\n114\t      return sslContext(serverName, useAlpn, false);\n115\t    } catch (Exception e) {\n116\t      throw new VertxException(e);\n117\t    }\n118\t  }\n119\t\n120\t  public SslContext sslContext(String serverName, boolean useAlpn, boolean server) throws Exception {\n121\t    int idx = idx(useAlpn);\n122\t    if (serverName != null) {\n123\t      KeyManagerFactory kmf = resolveKeyManagerFactory(serverName);\n124\t      TrustManager[] trustManagers = resolveTrustManagers(serverName);\n125\t      if (kmf != null || trustManagers != null || !server) {\n126\t        return sslContextMaps[idx].computeIfAbsent(serverName, s -> createContext(server, kmf, trustManagers, s, useAlpn));\n127\t      }\n128\t    }\n129\t    if (sslContexts[idx] == null) {\n130\t      SslContext context = createContext(server, null, null, serverName, useAlpn);\n131\t      sslCon