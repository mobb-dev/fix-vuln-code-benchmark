+  @Test
+  public void testProviderCacheIncludesClientAuth() throws Exception {
+    ContextInternal ctx = (ContextInternal) vertx.getOrCreateContext();
+    SslContextManager helper = new SslContextManager(new JdkSSLEngineOptions());
