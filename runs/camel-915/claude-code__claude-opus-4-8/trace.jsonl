pExchange cexchange = new CoapExchange(exchange, this);\n92\t        try {\n93\t            consumer = consumers.get(exchange.getRequest().getCode().name());\n94\t            if (consumer == null) {\n95\t                cexchange.respond(ResponseCode.METHOD_NOT_ALLOWED);\n96\t                return;\n97\t            }\n98\t\n99\t            camelExchange = consumer.createExchange(false);\n100\t            consumer.createUoW(camelExchange);\n101\t\n102\t            OptionSet options = exchange.getRequest().getOptions();\n103\t            for (String s : options.getUriQuery()) {\n104\t                int i = s.indexOf('=');\n105\t                if (i == -1) {\n106\t                    camelExchange.getIn().setHeader(s, \"\");\n107\t                } else {\n108\t                    camelExchange.getIn().setHeader(s.substring(0, i), s.substring(i + 1));\n109\t                }\n110\t            }\n111\t\n112\t            if (options.hasContentFormat()) {\n113\t                String mt = MediaTypeRegistry.toString(options.getContentFormat());\n114\t                camelExchange.getIn().setHeader(CoAPConstants.CONTENT_TYPE, mt);\n115\t            }\n116\t\n117\t            List<String> path = exchange.getRequest().getOptions().getUriPath();\n118\t            LinkedList<Resource> resources = new LinkedList<>();\n119\t            Resource r = this;\n120\t            while (r != null) {\n121\t                resources.push(r);\n122\t                r = r.getParent();\n123\t            }\n124\t            if (resources.getFirst().getName().isEmpty()) {\n125\t                resources.removeFirst();\n126\t            }\n127\t            int res = 0;\n128\t            while (!resources.isEmpty() && res < path.size()) {\n129\t                r = resources.removeFirst();\n130\t                if (r.getName().charAt(0) == '{' && r.getName().charAt(r.getName().length() - 1) == '}') {\n131\t                    String n = r.getName().substring(1, r.getName().length() - 1);\n132\t                    camelExchange.getIn().setHeader(n, path.get(res));\n133\t                }\n134\t                res++;\n135\t            }\n136\t\n137\t            byte[] bytes = exchange.getRequest().getPayload();\n138\t            camelExchange.getIn().setBody(bytes);\n139\t\n140\t            consumer.getProcessor().process(camelExchange);\n141\t            Message target = camelExchange.getMessage();\n142\t\n143\t            Long maxAge = target.getHeader(CoAPConstants.COAP_MAX_AGE, Long.class);\n144\t            if (maxAge != null) {\n145\t                cexchange.setMaxAge(maxAge);\n146\t            }\n147\t\n148\t            byte[] eTag = target.getHeader(CoAPConstants.COAP_ETAG, byte[].class);\n149\t            if (eTag != null) {\n150\t                cexchange.setETag(eTag);\n151\t            }\n152\t\n153\t            int format = MediaTypeRegistry.parse(target.getHeader(CoAPConstants.CONTENT_TYPE, String.class));\n154\t            cexchange.respond(ResponseCode.CONTENT, target.getBody(byte[].class), format);\n155\t\n156\t        } catch (Exception e) {\n157\t            cexchange.respond(ResponseCode.INTERNAL_SERVER_ERROR, e.getMessage());\n158\t        } finally {\n159\t            if (consumer != null) {\n160\t                if (camelExchange != null) {\n161\t                    consumer.doneUoW(camelExchange);\n162\t                }\n163\t                consumer.releaseExchange(camelExchange, false);\n164\t            } else {\n165\t                LOG.warn(\n166\t                        \"Skipping releasing the consumer exchange because the consumer is null. It may haven't been properly created earlier - exception was thrown\");\n167\t            }\n168\t        }\n169\t    }\n170\t}\n171\t"}]},"parent_tool_use_id":null,"session_id":"abea2b38-393a-4a0f-8f91-eb843fd2a806","uuid":"6b3ee06b-7023-453e-bca3-dd3f6c679fc5","timestamp":"2026-06-30T19:37:55.043Z","tool_use_result":{"type":"text","file":{"filePath":"/work/components/camel-coap/src/main/