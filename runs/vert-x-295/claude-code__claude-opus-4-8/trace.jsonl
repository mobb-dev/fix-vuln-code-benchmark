n175\t\n176\t  private static TrustOptions trustOptionsOf(SSLOptions sslOptions) {\n177\t    if (sslOptions instanceof ClientSSLOptions) {\n178\t      ClientSSLOptions clientSSLOptions = (ClientSSLOptions) sslOptions;\n179\t      if (clientSSLOptions.isTrustAll()) {\n180\t        return TrustAllOptions.INSTANCE;\n181\t      }\n182\t    }\n183\t    return sslOptions.getTrustOptions();\n184\t  }\n185\t\n186\t  private Future<Config> buildConfig(SSLOptions sslOptions, boolean force, ContextInternal ctx) {\n187\t    if (trustOptionsOf(sslOptions) == null && sslOptions.getKeyCertOptions() == null) {\n188\t      return ctx.succeededFuture(NULL_CONFIG);\n189\t    }\n190\t    Promise<Config> promise;\n191\t    ConfigKey k = new ConfigKey(sslOptions);\n192\t    synchronized (this) {\n193\t      if (force) {\n194\t        configMap.remove(k);\n195\t      } else {\n196\t        Future<Config> fut = configMap.get(k);\n197\t        if (fut != null) {\n198\t          return fut;\n199\t        }\n200\t      }\n201\t      promise = Promise.promise();\n202\t      configMap.put(k, promise.future());\n203\t    }\n204\t    ctx.executeBlockingInternal(() -> {\n205\t      KeyManagerFactory keyManagerFactory = null;\n206\t      Function<String, KeyManagerFactory> keyManagerFactoryMapper = null;\n207\t      TrustManagerFactory trustManagerFactory = null;\n208\t      Function<String, TrustManager[]> trustManagerMapper = null;\n209\t      List<CRL> crls = new ArrayList<>();\n210\t      if (sslOptions.getKeyCertOptions() != null) {\n211\t        keyManagerFactory = sslOptions.getKeyCertOptions().getKeyManagerFactory(ctx.owner());\n212\t        keyManagerFactoryMapper = sslOptions.getKeyCertOptions().keyManagerFactoryMapper(ctx.owner());\n213\t      }\n214\t      TrustOptions trustOptions = trustOptionsOf(sslOptions);\n215\t      if (trustOptions != null) {\n216\t        trustManagerFactory = trustOptions.getTrustManagerFactory(ctx.owner());\n217\t        trustManagerMapper = trustOptions.trus