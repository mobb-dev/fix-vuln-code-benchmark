ions = keyCertOptions;\n265\t      this.trustOptions = trustOptions;\n266\t      this.crlValues = crlValues != null ? new ArrayList<>(crlValues) : null;\n267\t    }\n268\t\n269\t    @Override\n270\t    public boolean equals(Object obj) {\n271\t      if (obj == this) {\n272\t        return true;\n273\t      }\n274\t      if (obj instanceof ConfigKey) {\n275\t        ConfigKey that = (ConfigKey) obj;\n276\t        return Objects.equals(keyCertOptions, that.keyCertOptions) && Objects.equals(trustOptions, that.trustOptions) && Objects.equals(crlValues, that.crlValues);\n277\t      }\n278\t      return false;\n279\t    }\n280\t\n281\t    @Override\n282\t    public int hashCode() {\n283\t      int hashCode = Objects.hashCode(keyCertOptions);\n284\t      hashCode = 31 * hashCode + Objects.hashCode(trustOptions);\n285\t      hashCode = 31 * hashCode + Objects.hashCode(crlValues);\n286\t      return hashCode;\n287\t    }\n288\t  }\n289\t\n290\t  private final static class Config {\n291\t    private final KeyManagerFactory keyManagerFactory;\n292\t    private final TrustManagerFactory trustManagerFactory;\n293\t    private final Function<String, KeyManagerFactory> keyManagerFactoryMapper;\n294\t    private final Function<String, TrustManager[]> trustManagerMapper;\n295\t    private final List<CRL> crls;\n296\t    public Config(KeyManagerFactory keyManagerFactory, TrustManagerFactory trustManagerFactory, Function<String, KeyManagerFactory> keyManagerFactoryMapper, Function<String, TrustManager[]> trustManagerMapper, List<CRL> crls) {\n297\t      this.keyManagerFactory = keyManagerFactory;\n298\t      this.trustManagerFactory = trustManagerFactory;\n299\t      this.keyManagerFactoryMapper = keyManagerFactoryMapper;\n300\t      this.trustManagerMapper = trustManagerMapper;\n301\t      this.crls = crls;\n302\t    }\n303\t  }\n304\t}\n305\t"}]},"parent_tool_use_id":null,"session_id":"adcdc8d6-c953-4ce7-b545-f3c6c9e0067a","uuid":"6e4a2dc8-0e7c-4c7c-af16-9ebd67e1ad22","timestamp":"2