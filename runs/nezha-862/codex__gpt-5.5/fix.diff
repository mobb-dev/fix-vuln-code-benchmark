+	t.Helper()
+
+	dispatchedCronTasks.Lock()
+	original := dispatchedCronTasks.count
+	dispatchedCronTasks.count = make(map[uint64]map[uint64]uint64)
+	dispatchedCronTasks.Unlock()
+
+	t.Cleanup(func() {
+		dispatchedCronTasks.Lock()
+		dispatchedCronTasks.count = original
+		dispatchedCronTasks.Unlock()
+	})
+}
