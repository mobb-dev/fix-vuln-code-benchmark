ory;\n44\timport javax.crypto.spec.PBEKeySpec;\n45\timport javax.crypto.spec.SecretKeySpec;\n46\t\n47\timport org.apache.hc.client5.http.auth.AuthChallenge;\n48\timport org.apache.hc.client5.http.auth.AuthScheme;\n49\timport org.apache.hc.client5.http.auth.AuthScope;\n50\timport org.apache.hc.client5.http.auth.AuthenticationException;\n51\timport org.apache.hc.client5.http.auth.Credentials;\n52\timport org.apache.hc.client5.http.auth.CredentialsProvider;\n53\timport org.apache.hc.client5.http.auth.MalformedChallengeException;\n54\timport org.apache.hc.client5.http.auth.StandardAuthScheme;\n55\timport org.apache.hc.client5.http.auth.UsernamePasswordCredentials;\n56\timport org.apache.hc.client5.http.protocol.HttpClientContext;\n57\timport org.apache.hc.core5.annotation.Contract;\n58\timport org.apache.hc.core5.annotation.Experimental;\n59\timport org.apache.hc.core5.annotation.ThreadingBehavior;\n60\timport org.apache.hc.core5.http.HttpHost;\n61\timport org.apache.hc.core5.http.HttpRequest;\n62\timport org.apache.hc.core5.http.NameValuePair;\n63\timport org.apache.hc.core5.http.protocol.HttpContext;\n64\timport org.apache.hc.core5.util.Args;\n65\timport org.slf4j.Logger;\n66\timport org.slf4j.LoggerFactory;\n67\t\n68\t\n69\t/**\n70\t * Strict HTTP SCRAM client implementing {@code SCRAM-SHA-256} per RFC&nbsp;7804\n71\t * with SCRAM core per RFC&nbsp;5802/7677.\n72\t * <p>HTTP SCRAM uses <em>no channel binding</em> (GS2 header {@code \"n,,\"}; {@code c=biws}).</p>\n73\t * <p><strong>Experimental:</strong> This API is work in progress and may change without notice in a future release.</p>\n74\t *\n75\t * @since 5.6\n76\t */\n77\t@Contract(threading = ThreadingBehavior.UNSAFE)\n78\t@Experimental\n79\tpublic final class ScramScheme implements AuthScheme {\n80\t\n81\t    private static final Logger LOG = LoggerFactory.getLogger(ScramScheme.class);\n82\t\n83\t    // RFC 7804 / RFC 5802 fixed no-CB GS2 header and its base64 value for 'c='\n84\t    private static final String GS2_HEADER = \"n,,\";\n85\t    private static final String C_BIND_B64 = \"biws\"; // base64(\"n,,\")\n86\t\n87\t    private static final Base64.Encoder B64 = Base64.getEncoder().withoutPadding();\n88\t    private static final Base64.Decoder B64D = Base64.getDecoder();\n89\t\n90\t    private enum State {\n91\t        INIT,\n92\t        ANNOUNCED,            // after 401 challenge without data\n93\t        CLIENT_FIRST_SENT,    // after Authorization with client-first\n94\t        SERVER_FIRST_RCVD,    // after 401 with data (r,s,i)\n95\t        CLIENT_FINAL_SENT,    // after Authorization with client-final (p=...)\n96\t        COMPLETE,             // after 2xx with matching v\n97\t        FAILED\n98\t    }\n99\t\n100\t    private final SecureRandom secureRandom;\n101\t    private final int warnMinIterations;\n102\t    private final int minIterationsRequired;\n103\t\n104\t    private State state = State.INIT;\n105\t    private boolean complete;\n106\t\n107\t    private String realm;\n108\t    private String sid;\n109\t\n110\t    private String username;     // SASLprep (query)\n111\t    private char[] password;     // SASLprep (stored), zeroed after use\n112\t    private Principal principal;\n113\t\n114\t    private String clientNonce;\n115\t    private String clientFirstBare;\n116\t    private String serverFirstRaw;\n117\t    private String serverNonce;\n118\t    private byte[] salt;\n119\t    private int iterations;\n120\t\n121\t    // Expected server signature (raw bytes) for constant-time check on Authentication-Info\n122\t    // (may appear on any final response status code)\n123\t    private byte[] expectedV;\n124\t\n125\t    /**\n126\t     * Default policy: warn if {@code i < 4096}, no hard enforcement; SHA-256 only.\n127\t     *\n128\t     * @since 5.6\n129\t     */\n130\t    public ScramScheme() {\n131\t        this(4096, 0, null);\n132\t    }\n133\t\n134\t    /**\n135\t     * Constructor with custom iteration policy.\n136\t     *\n137\t     * @param warnMinIterations     warn if iteration count is lower than this (0 disables warnings)\n138\t     * @param minIterationsRequired fail if iteration count is lower than this (0 disables enforcement)\n139\t     * @param rnd                   optional secure random source (null uses system default)\n140\t     * @since 5.6\n141\t     */\n142\t    public ScramScheme(final int warnMinIterations, final int minIterationsRequired, final SecureRandom rnd) {\n143\t        this.warnMinIterations = Math.max(0, warnMinIterations);\n144\t        this.minIterationsRequired = Math.max(0, minIterationsRequired);\n145\t        this.secureRandom = rnd != null ? rnd : new SecureRandom();\n146\t    }\n147\t\n148\t    /**\n149\t     * Returns textual designation of the scheme.\n150\t     *\n151\t     * @since 5.6\n152\t     */\n153\t    @Override\n154\t    public String getName() {\n155\t        return StandardAuthScheme.SCRAM_SHA_256;\n156\t    }\n157\t\n158\t    /**\n159\t     * SCRAM is per-request (no connection binding).\n160\t     *\n161\t     * @since 5.6\n162\t     */\n163\t    @Override\n164\t    public boolean isConnectionBased() {\n165\t        return false;\n166\t    }\n167\t\n168\t    /**\n169\t     * SCRAM must inspect final responses to verify {@code v=} in {@code Authentication-Info}.\n170\t     *\n171\t     * @since 5.6\n172\t     */\n173\t    @Override\n174\t    public boolean isChallengeExpected() {\n175\t        return true;\n176\t    }\n177\t\n178\t    /**\n179\t     * Legacy entry point: wraps {@link AuthenticationException} as {@link MalformedChallengeException}.\n180\t     *\n181\t     * @since 5.6\n182\t     */\n183\t    @Override\n184\t    public void processChallenge(final AuthChallenge authChallenge, final HttpContext context)\n185\t            throws MalformedChallengeException {\n186\t        try {\n187\t            processChallenge(null, true, authChallenge, context);\n188\t        } catch (final AuthenticationException ex) {\n189\t            throw new MalformedChallengeException(ex.getMessage(), ex);\n190\t        }\n191\t    }\n192\t\n193\t    /**\n194\t     * Handles 401 challenges (with/without {@code data}) and final responses carrying\n195\t     * {@code Authentication-Info} (any status code).\n196\t     *\n197\t     * @since 5.6\n198\t     */\n199\t    @Override\n200\t    public void processChallenge(\n201\t            final HttpHost host,\n202\t            final boolean challenged,\n203\t            final AuthChallenge authChallenge,\n204\t            final HttpContext context) throws MalformedChallengeException, AuthenticationException {\n205\t\n206\t        Args.notNull(context, \"HTTP context\");\n207\t\n208\t        if (authChallenge == null) {\n209\t            if (!challenged) {\n210\t                // Final response with no Authentication-Info: nothing to do\n211\t                return;\n212\t            }\n213\t            throw new MalformedChallengeException(\"Null SCRAM challenge\");\n214\t        }\n215\t\n216\t        final Map<String, String> params = toParamMap(authChallenge.getParams());\n217\t\n218\t        if (challenged) {\n219\t            // --- 401 path (WWW-Authenticate) ---\n220\t            final String scheme = authChallenge.getSchemeName();\n221\t            if (scheme == null || !StandardAuthScheme.SCRAM_SHA_256.equalsIgnoreCase(scheme)) {\n222\t                throw new MalformedChallengeException(\"Unexpected scheme: \" + scheme);\n223\t            }\n224\t\n225\t            final String data = params.get(\"data\");\n226\t            if (data == null) {\n227\t                // initial announce (no data)\n228\t                this.realm = params.get(\"realm\");\n229\t                this.state = State.ANNOUNCED;\n230\t                this.complete = false;\n231\t                zeroAndClearExpectedV();\n232\t                return;\n233\t            }\n234\t\n235\t            // server-first (data present)\n236\t            final String decoded = b64ToString(data);\n237\t            this.serverFirstRaw = decoded;\n238\t            final Map<String, String> attrs = parseAttrs(decoded);\n239\t\n240\t            final String r = attrs.get(\"r\");\n241\t            final String s = attrs.get(\"s\");\n242\t            final String i = attrs.get(\"i\");\n243\t            if (r == null || r.isEmpty() || s == null || s.isEmpty() || i == null || i.isEmpty()) {\n244\t                this.state = State.FAILED;\n245\t                throw new MalformedChallengeException(\"SCRAM server-first missing r/s/i\");\n246\t            }\n247\t            if (this.clientNonce == null || !r.startsWith(this.clientNonce)) {\n248\t                this.state = State.FAILED;\n249\t                throw new AuthenticationException(\"SCRAM server nonce does not start with client nonce\");\n250\t            }\n251\t\n252\t            this.sid = params.get(\"sid\");\n253\t            try {\n254\t                this.salt = B64D.decode(s);\n255\t                if (this.salt.length == 0) {\n256\t                    throw new IllegalArgumentException(\"empty salt\");\n257\t                }\n258\t            } catch (final IllegalArgumentException e) {\n259\t                this.state = State.FAILED;\n260\t                throw new MalformedChallengeException(\"Invalid base64 salt\", e);\n261\t            }\n262\t            try {\n263\t                this.iterations = Integer.parseInt(i);\n264\t                if (this.iterations <= 0) {\n265\t                    throw new NumberFormatException(\"i<=0\");\n266\t                }\n267\t            } catch (final NumberFormatException e) {\n268\t                this.state = State.FAILED;\n269\t                throw new MalformedChallengeException(\"Invalid iteration count\", e);\n270\t            }\n271\t\n272\t            if (this.minIterationsRequired > 0 && this.iterations < this.minIterationsRequired) {\n273\t                this.state = State.FAILED;\n274\t                throw new AuthenticationException(\n275\t                        \"SCRAM iteration count below required minimum: \" + this.iterations + \" < \" + this.minIterationsRequired);\n276\t            }\n277\t            if (this.warnMinIterations > 0 && this.iterations < this.warnMinIterations && LOG.isWarnEnabled()) {\n278\t                LOG.warn(\"SCRAM iteration count ({}) lower than recommended ({})\", this.iterations, warnMinIterations);\n279\t            }\n280\t\n281\t            this.serverNonce = r;\n282\t            this.state = State.SERVER_FIRST_RCVD;\n283\t            this.complete = false;\n284\t            zeroAndClearExpectedV();\n285\t            return;\n286\t        }\n287\t\n288\t        // --- final-response path (Authentication-Info on any status) ---\n289\t        // For Authentication-Info, RFC 7804 does NOT mandate a scheme token; do NOT enforce scheme name here.\n290\t        final String data = params.get(\"data\");\n291\t        if (data == null) {\n292\t            return;\n293\t        }\n294\t        final String decoded = b64ToString(data);\n295\t        final Map<String, String> attrs = parseAttrs(decoded);\n296\t        final String err = attrs.get(\"e\");\n297\t        if (err != null) {\n298\t            this.state = State.FAILED;\n299\t            if (err.isEmpty()) {\n300\t                throw new MalformedChallengeException(\"SCRAM server error attribute 'e' is empty\");\n301\t            }\n302\t            throw new AuthenticationException(\"SCRAM server error: \" + err);\n303\t        }\n304\t        final String vB64 = attrs.get(\"v\");\n305\t        if (vB64 == null) {\n306\t            return;\n307\t        }\n308\t\n309\t        // compare 'v' in constant time; treat bad base64 for v as a signature mismatch (tests expect \"signature\")\n310\t        final byte[] expected = this.expectedV;\n311\t        this.expectedV = null; // clear reference early\n312\t\n313\t        byte[] vBytes = null;\n314\t        boolean match;\n315\t        try {\n316\t            vBytes = B64D.decode(vB64);\n317\t            match = expected != null && MessageDigest.isEqual(expected, vBytes);\n318\t        } catch (final IllegalArgumentException e) {\n319\t            match = false; // invalid base64 for v -> treat as mismatch\n320\t        } finally {\n321\t            zero(vBytes);\n322\t            zero(expected);\n323\t        }\n324\t\n325\t        if (!match) {\n326\t            this.state = State.FAILED;\n327\t            throw new MalformedChallengeException(\"SCRAM server signature mismatch\");\n328\t        }\n329\t        this.complete = true;\n330\t        this.state = State.COMPLETE;\n331\t    }\n332\t\n333\t    /**\n334\t     * @since 5.6\n335\t     */\n336\t    @Override\n337\t    public boolean isChallengeComplete() {\n338\t        return this.complete || this.state == State.COMPLETE || this.state == State.FAILED;\n339\t    }\n340\t\n341\t    /**\n342\t     * @since 5.6\n343\t     */\n344\t    @Override\n345\t    public String getRealm() {\n346\t        return this.realm;\n347\t    }\n348\t\n349\t    /**\n350\t     * Allow response when:\n351\t     * - INIT  (preemptive client-first) — only if creds have been prepared\n352\t     * - ANNOUNCED (401 without data)\n353\t     * - SERVER_FIRST_RCVD (ready to send client-final)\n354\t     *\n355\t     * @since 5.6\n356\t     */\n357\t    @Override\n358\t    public boolean isResponseReady(\n359\t            final HttpHost host,\n360\t            final CredentialsProvider credentialsProvider,\n361\t            final HttpContext context) throws AuthenticationException {\n362\t\n363\t        Args.notNull(credentialsProvider, \"Credentials provider\");\n364\t\n365\t        final HttpClientContext clientContext = HttpClientContext.cast(context);\n366\t        final AuthScope scope = new AuthScope(host, this.realm, getName());\n367\t        final Credentials creds = credentialsProvider.getCredentials(scope, clientContext);\n368\t        if (!(creds instanceof UsernamePasswordCredentials)) {\n369\t            return false;\n370\t        }\n371\t        final UsernamePasswordCredentials up = (UsernamePasswordCredentials) creds;\n372\t\n373\t        // SASLprep: username as query, password as stored\n374\t        final String preppedUser;\n375\t        final char[] passChars = up.getUserPassword() != null ? up.getUserPassword().clone() : null;\n376\t        try {\n377\t            preppedUser = SaslPrep.INSTANCE.prepAsQueryString(up.getUserName());\n378\t            final String preppedPassStr = SaslPrep.INSTANCE.prepAsStoredString(\n379\t                    passChars != null ? new String(passChars) : null);\n380\t            this.username = preppedUser;\n381\t            this.password = preppedPassStr != null ? preppedPassStr.toCharArray() : null;\n382\t        } catch (final Exception e) {\n383\t            throw new AuthenticationException(\"SASLprep failed\", e);\n384\t        } finally {\n385\t            if (passChars != null) {\n386\t                Arrays.fill(passChars, '\\0');\n387\t            }\n388\t        }\n389\t\n390\t        this.principal = new SimplePrincipal(this.username);\n391\t\n392\t        switch (this.state) {\n393\t            case INIT: // allow preemptive\n394\t            case ANNOUNCED:\n395\t            case SERVER_FIRST_RCVD:\n396\t                return true;\n397\t            default:\n398\t                return false;\n399\t        }\n400\t    }\n401\t\n402\t    /**\n403\t     * @since 5.6\n404\t     */\n405\t    @Override\n406\t    public String generateAuthResponse(\n407\t            final HttpHost host,\n408\t            final HttpRequest request,\n409\t            final HttpContext context) throws AuthenticationException {\n410\t\n411\t        switch (this.state) {\n412\t            case INIT:\n413\t                // Allow preemptive only if credentials were prepared already\n414\t                if (this.username == null) {\n415\t                    this.state = State.FAILED;\n416\t                    throw new AuthenticationException(\"SCRAM state out of sequence: INIT without credentials\");\n417\t                }\n418\t                return buildClientFirst();\n419\t            case ANNOUNCED:\n420\t                return buildClientFirst();\n421\t            case SERVER_FIRST_RCVD:\n422\t                return buildClientFinalAndExpectV();\n423\t            default:\n424\t                this.state = State.FAILED;\n425\t                throw new AuthenticationException(\"SCRAM state out of sequence: \" + this.state);\n426\t        }\n427\t    }\n428\t\n429\t    /**\n430\t     * Returns {@link Principal} whose credentials are used.\n431\t     *\n432\t     * @since 5.6\n433\t     */\n434\t    @Override\n435\t    public Principal getPrincipal() {\n436\t        return this.principal;\n437\t    }\n438\t\n439\t    // ---------------- internals ----------------\n440\t\n441\t    private String buildClientFirst() {\n442\t        this.clientNonce = genNonce();\n443\t        final String escUser = escapeUser(this.username);\n444\t        this.clientFirstBare = \"n=\" + escUser + \",r=\" + this.clientNonce;\n445\t\n446\t        // RFC 7804: data = base64(GS2 header + client-first-bare)\n447\t        final String data = stringToB64(GS2_HEADER + this.clientFirstBare);\n448\t\n449\t        final StringBuilder sb = new StringBuilder(64);\n450\t        sb.append(StandardAuthScheme.SCRAM_SHA_256).append(' ');\n451\t        if (this.realm != null) {\n452\t            sb.append(\"realm=\").append(quoteParam(this.realm)).append(\", \");\n453\t        }\n454\t        sb.append(\"data=\").append(quoteParam(data)); // quoted per RFC 7804\n455\t        this.state = State.CLIENT_FIRST_SENT;\n456\t        this.complete = false;\n457\t        zeroAndClearExpectedV();\n458\t        return sb.toString();\n459\t    }\n460\t\n461\t    private String buildClientFinalAndExpectV() throws AuthenticationException {\n462\t        byte[] salted = null, clientKey = null, storedKey = null, clientSignature = null,\n463\t                clientProof = null, serverKey = null, serverSignature = null;\n464\t\n465\t        try {\n466\t            // HTTP SCRAM: no CB -> c=biws\n467\t            final String clientFinalNoProof = \"c=\" + C_BIND_B64 + \",r=\" + this.serverNonce;\n468\t            final String authMessage = this.clientFirstBare + \",\" + this.serverFirstRaw + \",\" + clientFinalNoProof;\n469\t\n470\t            salted = hiPBKDF2(this.password, this.salt, this.iterations, 32);\n471\t            clientKey = hmac(salted, \"Client Key\");\n472\t            storedKey = sha256(clientKey);\n473\t            clientSignature = hmac(storedKey, authMessage);\n474\t            clientProof = xor(clientKey, clientSignature);\n475\t            final String pB64 = B64.encodeToString(clientProof);\n476\t\n477\t            serverKey = hmac(salted, \"Server Key\");\n478\t            serverSignature = hmac(serverKey, authMessage);\n479\t\n480\t            // Stash expected v (raw) for constant-time check on 2xx\n481\t            zeroAndClearExpectedV();\n482\t            this.expectedV = serverSignature.clone();\n483\t\n484\t            final String clientFinal = clientFinalNoProof + \",p=\" + pB64;\n485\t            final String data = stringToB64(clientFinal);\n486\t\n487\t            final StringBuilder sb = new StringBuilder(64);\n488\t            sb.append(StandardAuthScheme.SCRAM_SHA_256).append(' ');\n489\t            if (this.sid != null) {\n490\t                sb.append(\"sid=\").append(quoteParam(this.sid)).append(\", \");\n491\t            }\n492\t            sb.append(\"data=\").append(quoteParam(data)); // quoted\n493\t\n494\t            this.state = State.CLIENT_FINAL_SENT;\n495\t            this.complete = false;\n496\t            return sb.toString();\n497\t        } catch (final GeneralSecurityException e) {\n498\t            this.state = State.FAILED;\n499\t            throw new AuthenticationException(\"SCRAM crypto failure\", e);\n500\t        } finally {\n501\t            if (this.password != null) {\n502\t                Arrays.fill(this.password, '\\0');\n503\t                this.password = null;\n504\t            }\n505\t            zero(salted);\n506\t            zero(clientKey);\n507\t            zero(storedKey);\n508\t            zero(clientSignature);\n509\t            zero(clientProof);\n510\t            zero(serverKey);\n511\t            // clone held in expectedV\n512\t            zero(serverSignature);\n513\t        }\n514\t    }\n515\t\n516\t    private static void zero(final byte[] a) {\n517\t        if (a != null) {\n518\t            Arrays.fill(a, (byte) 0);\n519\t        }\n520\t    }\n521\t\n522\t    private void zeroAndClearExpectedV() {\n523\t        if (this.expectedV != null) {\n524\t            zero(this.expectedV);\n525\t            this.expectedV = null;\n526\t        }\n527\t    }\n528\t\n529\t    private static Map<String, String> toParamMap(final List<NameValuePair> pairs) {\n530\t        final Map<String, String> m = new HashMap<>();\n531\t        if (pairs != null) {\n532\t            for (final NameValuePair p : pairs) {\n533\t                if (p != null && p.getName() != null) {\n534\t                    m.put(p.getName().toLowerCase(Locale.ROOT), p.getValue());\n535\t                }\n536\t            }\n537\t        }\n538\t        return m;\n539\t    }\n540\t\n541\t    // Parse \"k=v(,k=v)*\" with RFC 5802 escapes: \"=2C\"/\"=2c\" -> \",\", \"=3D\"/\"=3d\" -> \"=\"\n542\t    private static Map<String, String> parseAttrs(final String s) throws MalformedChallengeException {\n543\t        final Map<String, String> out = new LinkedHashMap<>();\n544\t        int i = 0;\n545\t        while (i < s.length()) {\n546\t            if (i + 2 > s.length() || s.charAt(i + 1) != '=') {\n547\t                throw new MalformedChallengeException(\"Bad SCRAM attr at index \" + i);\n548\t            }\n549\t            final String k = String.valueOf(s.charAt(i));\n550\t            i += 2;\n551\t            final StringBuilder v = new StringBuilder();\n552\t            while (i < s.length()) {\n553\t                final char c = s.charAt(i);\n554\t                if (c == ',') {\n555\t                    i++;\n556\t                    break;\n557\t                }\n558\t                if (c == '=' && i + 2 < s.length()) {\n559\t                    final String esc = s.substring(i, i + 3);\n560\t                    if (\"=2C\".equalsIgnoreCase(esc)) {\n561\t                        v.append(',');\n562\t                        i += 3;\n563\t                        continue;\n564\t                    }\n565\t                    if (\"=3D\".equalsIgnoreCase(esc)) {\n566\t                        v.append('=');\n567\t                        i += 3;\n568\t                        continue;\n569\t                    }\n570\t                }\n571\t                v.append(c);\n572\t                i++;\n573\t            }\n574\t            out.put(k, v.toString());\n575\t        }\n576\t        return out;\n577\t    }\n578\t\n579\t    private String genNonce() {\n580\t        final byte[] buf = new byte[16];\n581\t        this.secureRandom.nextBytes(buf);\n582\t        final StringBuilder sb = new StringBuilder(buf.length * 2);\n583\t        for (final byte b : buf) {\n584\t            final int v = b & 0xff;\n585\t            if (v < 0x10) {\n586\t                sb.append('0');\n587\t            }\n588\t            sb.append(Integer.toHexString(v));\n589\t        }\n590\t        return sb.toString();\n591\t    }\n592\t\n593\t    private static String escapeUser(final String user) {\n594\t        if (user == null) {\n595\t            // Defensive for tests that skip isResponseReady() before client-first\n596\t            return \"\";\n597\t        }\n598\t        final StringBuilder sb = new StringBuilder(user.length() + 8);\n599\t        for (int i = 0; i < user.length(); i++) {\n600\t            final char c = user.charAt(i);\n601\t            if (c == ',') {\n602\t                sb.append(\"=2C\");\n603\t            } else if (c == '=') {\n604\t                sb.append(\"=3D\");\n605\t            } else {\n606\t                sb.append(c);\n607\t            }\n608\t        }\n609\t        return sb.toString();\n610\t    }\n611\t\n612\t    private static String quoteParam(final String v) {\n613\t        if (v == null) {\n614\t            return \"\\\"\\\"\";\n615\t        }\n616\t        final StringBuilder sb = new StringBuilder(v.length() + 2);\n617\t        sb.append('\"');\n618\t        for (int i = 0; i < v.length(); i++) {\n619\t            final char c = v.charAt(i);\n620\t            if (c == '\\\\' || c == '\"') {\n621\t                sb.append('\\\\');\n622\t            }\n623\t            sb.append(c);\n624\t        }\n625\t        sb.append('\"');\n626\t        return sb.toString();\n627\t    }\n628\t\n629\t    private static byte[] hiPBKDF2(final char[] password, final byte[] salt, final int iterations, final int dkLen)\n630\t            throws GeneralSecurityException {\n631\t        final PBEKeySpec spec = new PBEKeySpec(password, salt, iterations, dkLen * 8);\n632\t        return SecretKeyFactory.getInstance(\"PBKDF2WithHmacSHA256\").generateSecret(spec).getEncoded();\n633\t    }\n634\t\n635\t    private static byte[] hmac(final byte[] key, final String msg) throws GeneralSecurityException {\n636\t        final Mac mac = Mac.getInstance(\"HmacSHA256\");\n637\t        mac.init(new SecretKeySpec(key, \"HmacSHA256\"));\n638\t        return mac.doFinal(msg.getBytes(StandardCharsets.UTF_8));\n639\t    }\n640\t\n641\t    private static byte[] sha256(final byte[] in) throws GeneralSecurityException {\n642\t        return MessageDigest.getInstance(\"SHA-256\").digest(in);\n643\t    }\n644\t\n645\t    private static byte[] xor(final byte[] a, final byte[] b) {\n646\t        final int len = Math.min(a.length, b.length);\n647\t        final byte[] out = new byte[len];\n648\t        for (int i = 0; i < len; i++) {\n649\t            out[i] = (byte) (a[i] ^ b[i]);\n650\t        }\n651\t        return out;\n652\t    }\n653\t\n654\t    private static String stringToB64(final String s) {\n655\t        return B64.encodeToString(s.getBytes(StandardCharsets.UTF_8));\n656\t    }\n657\t\n658\t    private static String b64ToString(final String b64) throws MalformedChallengeException {\n659\t        try {\n660\t            return new String(B64D.decode(b64), StandardCharsets.UTF_8);\n661\t        } catch (final IllegalArgumentException e) {\n662\t            throw new MalformedChallengeException(\"Bad base64 'data' value\", e);\n663\t        }\n664\t    }\n665\t\n666\t    private static final class SimplePrincipal implements Principal {\n667\t        private final String name;\n668\t\n669\t        private SimplePrincipal(final String name) {\n670\t            this.name = name;\n671\t        }\n672\t\n673\t        @Override\n674\t        public String getName() {\n675\t            return this.name;\n676\t        }\n677\t\n678\t        @Override\n679\t        public String toString() {\n680\t            return this.name;\n681\t        }\n682\t    }\n683\t\n684\t}\n685\t"}]},"parent_tool_use_id":null,"session_id":"5665b4ee-91a6-440c-8356-8a437f36e942","uuid":"4ffecacb-36a2-42b0-bfef-b1e5b1960c5b","timestamp":"2026-06-30T20:29:43.801Z","tool_use_result":{"type":"text","file":{"filePath":"/work/httpclient5/src/main/java/org/apache/hc/client5/http/impl/auth/ScramScheme.java","content":"/*\n * ====================================================================\n * Licensed to the Apache Software Foundation (ASF) under one\n * or more contributor license agreements.  See the NOTICE file\n * distributed with this work for additional information\n * regarding copyright ownership.  The ASF licenses this file\n * to you under the Apache License, Version 2.0 (the\n * \"License\"); you may not use this file except in compliance\n * with the License.  You may obtain a copy of the License at\n *\n *   http://www.apache.org/licenses/LICENSE-2.0\n *\n * Unless required by applicable law or agreed to in writing,\n * software distributed under the License is distributed on an\n * \"AS IS\" BASIS, WITHOUT WARRANTIES OR CONDITIONS OF ANY\n * KIND, either express or implied.  See the License for the\n * specific language governing permissions and limitations\n * under the License.\n * ====================================================================\n *\n * This software consists of voluntary contributions made by many\n * individuals on behalf of the Apache Software Foundation.  For more\n * information on the Apache Software Foundation, please see\n * <http://www.apache.org/>.\n *\n */\npackage org.apache.hc.client5.http.impl.auth;\n\nimport java.nio.charset.StandardCharsets;\nimport java.security.GeneralSecurityException;\nimport java.security.MessageDigest;\nimport java.security.Principal;\nimport java.security.SecureRandom;\nimport java.util.Arrays;\nimport java.util.Base64;\nimport java.util.HashMap;\nimport java.util.LinkedHashMap;\nimport java.util.List;\nimport java.util.Locale;\nimport java.util.Map;\n\nimport javax.crypto.Mac;\nimport javax.crypto.SecretKeyFactory;\nimport javax.crypto.spec.PBEKeySpec;\nimport javax.crypto.spec.SecretKeySpec;\n\nimport org.apache.hc.client5.http.auth.AuthChallenge;\nimport org.apache.hc.client5.http.auth.AuthScheme;\nimport org.apache.hc.client5.http.auth.AuthScope;\nimport org.apache.hc.client5.http.auth.AuthenticationException;\nimport org.apache.hc.client5.http.auth.Credentials;\nimport org.apache.hc.client5.http.auth.CredentialsProvider;\nimport org.apache.hc.client5.http.auth.MalformedChallengeException;\nimport org.apache.hc.client5.http.auth.StandardAuthScheme;\nimport org.apache.hc.client5.http.auth.UsernamePasswordCredentials;\nimport org.apache.hc.client5.http.protocol.HttpClientContext;\nimport org.apache.hc.core5.annotation.Contract;\nimport org.apache.hc.core5.annotation.Experimental;\nimport org.apache.hc.core5.annotation.ThreadingBehavior;\nimport org.apache.hc.core5.http.HttpHost;\nimport org.apache.hc.core5.http.HttpRequest;\nimport org.apache.hc.core5.http.NameValuePair;\nimport org.apache.hc.core5.http.protocol.HttpContext;\nimport org.apache.hc.core5.util.Args;\nimport org.slf4j.Logger;\nimport org.slf4j.LoggerFactory;\n\n\n/**\n * Strict HTTP SCRAM client implementing {@code SCRAM-SHA-256} per RFC&nbsp;7804\n * with SCRAM core per RFC&nbsp;5802/7677.\n * <p>HTTP SCRAM uses <em>no channel binding</em> (GS2 header {@code \"n,,\"}; {@code c=biws}).</p>\n * <p><strong>Experimental:</strong> This API is work in progress and may change without notice in a future release.</p>\n *\n * @since 5.6\n */\n@Contract(threading = ThreadingBehavior.UNSAFE)\n@Experimental\npublic final class ScramScheme implements AuthScheme {\n\n    private static final Logger LOG = LoggerFactory.getLogger(ScramScheme.class);\n\n    // RFC 7804 / RFC 5802 fixed no-CB GS2 header and its base64 value for 'c='\n    private static final String GS2_HEADER = \"n,,\";\n    private static final String C_BIND_B64 = \"biws\"; // base64(\"n,,\")\n\n    private static final Base64.Encoder B64 = Base64.getEncoder().withoutPadding();\n    private static final Base64.Decoder B64D = Base64.getDecoder();\n\n    private enum State {\n        INIT,\n        ANNOUNCED,            // after 401 challenge without data\n        CLIENT_FIRST_SENT,    // after Authorization with client-first\n        SERVER_FIRST_RCVD,    // after 401 with data (r,s,i)\n        CLIENT_FINAL_SENT,    // after Authorization with client-final (p=...)\n        COMPLETE,             // after 2xx with matching v\n        FAILED\n    }\n\n    private final SecureRandom secureRandom;\n    private final int warnMinIterations;\n    private final int minIterationsRequired;\n\n    private State state = State.INIT;\n    private boolean complete;\n\n    private String realm;\n    private String sid;\n\n    private String username;     // SASLprep (query)\n    private char[] password;     // SASLprep (stored), zeroed after use\n    private Principal principal;\n\n    private String clientNonce;\n    private String clientFirstBare;\n    private String serverFirstRaw;\n    private String serverNonce;\n    private byte[] salt;\n    private int iterations;\n\n    // Expected server signature (raw bytes) for constant-time check on Authentication-Info\n    // (may appear on any final response status code)\n    private byte[] expectedV;\n\n    /**\n     * Default policy: warn if {@code i < 4096}, no hard enforcement; SHA-256 only.\n     *\n     * @since 5.6\n     */\n    public ScramScheme() {\n        this(4096, 0, null);\n    }\n\n    /**\n     * Constructor with custom iteration policy.\n     *\n     * @param warnMinIterations     warn if iteration count is lower than this (0 disables warnings)\n     * @param minIterationsRequired fail if iteration count is lower than this (0 disables enforcement)\n     * @param rnd                   optional secure random source (null uses system default)\n     * @since 5.6\n     */\n    public ScramScheme(final int warnMinIterations, final int minIterationsRequired, final SecureRandom rnd) {\n        this.warnMinIterations = Math.max(0, warnMinIterations);\n        this.minIterationsRequired = Math.max(0, minIterationsRequired);\n        this.secureRandom = rnd != null ? rnd : new SecureRandom();\n    }\n\n    /**\n     * Returns textual designation of the scheme.\n     *\n     * @since 5.6\n     */\n    @Override\n    public String getName() {\n        return StandardAuthScheme.SCRAM_SHA_256;\n    }\n\n    /**\n     * SCRAM is per-request (no connection binding).\n     *\n     * @since 5.6\n     */\n    @Override\n    public boolean isConnectionBased() {\n        return false;\n    }\n\n    /**\n     * SCRAM must inspect final responses to verify {@code v=} in {@code Authentication-Info}.\n     *\n     * @since 5.6\n     */\n    @Override\n    public boolean isChallengeExpected() {\n        return true;\n    }\n\n    /**\n     * Legacy entry point: wraps {@link AuthenticationException} as {@link MalformedChallengeException}.\n     *\n     * @since 5.6\n     */\n    @Override\n    public void processChallenge(final AuthChallenge authChallenge, final HttpContext context)\n            throws MalformedChallengeException {\n        try {\n            processChallenge(null, true, authChallenge, context);\n        } catch (final AuthenticationException ex) {\n            throw new MalformedChallengeException(ex.getMessage(), ex);\n        }\n    }\n\n    /**\n     * Handles 401 challenges (with/without {@code data}) and final responses carrying\n     * {@code Authentication-Info} (any status code).\n     *\n     * @since 5.6\n     */\n    @Override\n    public void processChallenge(\n            final HttpHost host,\n            final boolean challenged,\n            final AuthChallenge authChallenge,\n            final HttpContext context) throws MalformedChallengeException, AuthenticationException {\n\n        Args.notNull(context, \"HTTP context\");\n\n        if (authChallenge == null) {\n            if (!challenged) {\n                // Final response with no Authentication-Info: nothing to do\n                return;\n            }\n            throw new MalformedChallengeException(\"Null SCRAM challenge\");\n        }\n\n        final Map<String, String> params = toParamMap(authChallenge.getParams());\n\n        if (challenged) {\n            // --- 401 path (WWW-Authenticate) ---\n            final String scheme = authChallenge.getSchemeName();\n            if (scheme == null || !StandardAuthScheme.SCRAM_SHA_256.equalsIgnoreCase(scheme)) {\n                throw new MalformedChallengeException(\"Unexpected scheme: \" + scheme);\n            }\n\n            final String data = params.get(\"data\");\n            if (data == null) {\n                // initial announce (no data)\n                this.realm = params.get(\"realm\");\n                this.state = State.ANNOUNCED;\n                this.complete = false;\n                zeroAndClearExpectedV();\n                return;\n            }\n\n            // server-first (data present)\n            final String decoded = b64ToString(data);\n            this.serverFirstRaw = decoded;\n            final Map<String, String> attrs = parseAttrs(decoded);\n\n            final String r = attrs.get(\"r\");\n            final String s = attrs.get(\"s\");\n            final String i = attrs.get(\"i\");\n            if (r == null || r.isEmpty() || s == null || s.isEmpty() || i == null || i.isEmpty()) {\n                this.state = State.FAILED;\n                throw new MalformedChallengeException(\"SCRAM server-first missing r/s/i\");\n            }\n            if (this.clientNonce == null || !r.startsWith(this.clientNonce)) {\n                this.state = State.FAILED;\n                throw new AuthenticationException(\"SCRAM server nonce does not start with client nonce\");\n            }\n\n            this.sid = params.get(\"sid\");\n            try {\n                this.salt = B64D.decode(s);\n                if (this.salt.length == 0) {\n                    throw new IllegalArgumentException(\"empty salt\");\n                }\n            } catch (final IllegalArgumentException e) {\n                this.state = State.FAILED;\n                throw new MalformedChallengeException(\"Invalid base64 salt\", e);\n            }\n            try {\n                this.iterations = Integer.parseInt(i);\n                if (this.iterations <= 0) {\n                    throw new NumberFormatException(\"i<=0\");\n                }\n            } catch (final NumberFormatException e) {\n                this.state = State.FAILED;\n                throw new MalformedChallengeException(\"Invalid iteration count\", e);\n            }\n\n            if (this.minIterationsRequired > 0 && this.iterations < this.minIterationsRequired) {\n                this.state = State.FAILED;\n                throw new AuthenticationException(\n                        \"SCRAM iteration count below required minimum: \" + this.iterations + \" < \" + this.minIterationsRequired);\n            }\n            if (this.warnMinIterations > 0 && this.iterations < this.warnMinIterations && LOG.isWarnEnabled()) {\n                LOG.warn(\"SCRAM iteration count ({}) lower than recommended ({})\", this.iterations, warnMinIterations);\n            }\n\n            this.serverNonce = r;\n            this.state = State.SERVER_FIRST_RCVD;\n            this.complete = false;\n            zeroAndClearExpectedV();\n            return;\n        }\n\n        // --- final-response path (Authentication-Info on any status) ---\n        // For Authentication-Info, RFC 7804 does NOT mandate a scheme token; do NOT enforce scheme name here.\n        final String data = params.get(\"data\");\n        if (data == null) {\n            return;\n        }\n        final String decoded = b64ToString(data);\n        final Map<String, String> attrs = parseAttrs(decoded);\n        final String err = attrs.get(\"e\");\n        if (err != null) {\n            this.state = State.FAILED;\n            if (err.isEmpty()) {\n                throw new MalformedChallengeException(\"SCRAM server error attribute 'e' is empty\");\n            }\n            throw new AuthenticationException(\"SCRAM server error: \" + err);\n        }\n        final String vB64 = attrs.get(\"v\");\n        if (vB64 == null) {\n            return;\n        }\n\n        // compare 'v' in constant time; treat bad base64 for v as a signature mismatch (tests expect \"signature\")\n        final byte[] expected = this.expectedV;\n        this.expectedV = null; // clear reference early\n\n        byte[] vBytes = null;\n        boolean match;\n        try {\n            vBytes = B64D.decode(vB64);\n            match = expected != null && MessageDigest.isEqual(expected, vBytes);\n        } catch (final IllegalArgumentException e) {\n            match = false; // invalid base64 for v -> treat as mismatch\n        } finally {\n            zero(vBytes);\n            zero(expected);\n        }\n\n        if (!match) {\n            this.state = State.FAILED;\n            throw new MalformedChallengeException(\"SCRAM server signature mismatch\");\n        }\n        this.complete = true;\n        this.state = State.COMPLETE;\n    }\n\n    /**\n     * @since 5.6\n     */\n    @Override\n    public boolean isChallengeComplete() {\n        return this.complete || this.state == State.COMPLETE || this.state == State.FAILED;\n    }\n\n    /**\n     * @since 5.6\n     */\n    @Override\n    public String getRealm() {\n        return this.realm;\n    }\n\n    /**\n     * Allow response when:\n     * - INIT  (preemptive client-first) — only if creds have been prepared\n     * - ANNOUNCED (401 without data)\n     * - SERVER_FIRST_RCVD (ready to send client-final)\n     *\n     * @since 5.6\n     */\n    @Override\n    public boolean isResponseReady(\n            final HttpHost host,\n            final CredentialsProvider credentialsProvider,\n            final HttpContext context) throws AuthenticationException {\n\n        Args.notNull(credentialsProvider, \"Credentials provider\");\n\n        final HttpClientContext clientContext = HttpClientContext.cast(context);\n        final AuthScope scope = new AuthScope(host, this.realm, getName());\n        final Credentials creds = credentialsProvider.getCredentials(scope, clientContext);\n        if (!(creds instanceof UsernamePasswordCredentials)) {\n            return false;\n        }\n        final UsernamePasswordCredentials up = (UsernamePasswordCredentials) creds;\n\n        // SASLprep: username as query, password as stored\n        final String preppedUser;\n        final char[] passChars = up.getUserPassword() != null ? up.getUserPassword().clone() : null;\n        try {\n            preppedUser = SaslPrep.INSTANCE.prepAsQueryString(up.getUserName());\n            final String preppedPassStr = SaslPrep.INSTANCE.prepAsStoredString(\n                    passChars != null ? new String(passChars) : null);\n            this.username = preppedUser;\n            this.password = preppedPassStr != null ? preppedPassStr.toCharArray() : null;\n        } catch (final Exception e) {\n            throw new AuthenticationException(\"SASLprep failed\", e);\n        } finally {\n            if (passChars != null) {\n                Arrays.fill(passChars, '\\0');\n            }\n        }\n\n        this.principal = new SimplePrincipal(this.username);\n\n        switch (this.state) {\n            case INIT: // allow preemptive\n            case ANNOUNCED:\n            case SERVER_FIRST_RCVD:\n                return true;\n            default:\n                return false;\n        }\n    }\n\n    /**\n     * @since 5.6\n     */\n    @Override\n    public String generateAuthResponse(\n            final HttpHost host,\n            final HttpRequest request,\n            final HttpContext context) throws AuthenticationException {\n\n        switch (this.state) {\n            case INIT:\n                // Allow preemptive only if credentials were prepared already\n                if (this.username == null) {\n                    this.state = State.FAILED;\n                    throw new AuthenticationException(\"SCRAM state out of sequence: INIT without credentials\");\n                }\n                return buildClientFirst();\n            case ANNOUNCED:\n                return buildClientFirst();\n            case SERVER_FIRST_RCVD:\n                return buildClientFinalAndExpectV();\n            default:\n                this.state = State.FAILED;\n                throw new AuthenticationException(\"SCRAM state out of sequence: \" + this.state);\n        }\n    }\n\n    /**\n     * Returns {@link Principal} whose credentials are used.\n     *\n     * @since 5.6\n     */\n    @Override\n    public Principal getPrincipal() {\n        return this.principal;\n    }\n\n    // ---------------- internals ----------------\n\n    private String buildClientFirst() {\n        this.clientNonce = genNonce();\n        final String escUser = escapeUser(this.username);\n        this.clientFirstBare = \"n=\" + escUser + \",r=\" + this.clientNonce;\n\n        // RFC 7804: data = base64(GS2 header + client-first-bare)\n        final String data = stringToB64(GS2_HEADER + this.clientFirstBare);\n\n        final StringBuilder sb = new StringBuilder(64);\n        sb.append(StandardAuthScheme.SCRAM_SHA_256).append(' ');\n        if (this.realm != null) {\n            sb.append(\"realm=\").append(quoteParam(this.realm)).append(\", \");\n        }\n        sb.append(\"data=\").append(quoteParam(data)); // quoted per RFC 7804\n        this.state = State.CLIENT_FIRST_SENT;\n        this.complete = false;\n        zeroAndClearExpectedV();\n        return sb.toString();\n    }\n\n    private String buildClientFinalAndExpectV() throws AuthenticationException {\n        byte[] salted = null, clientKey = null, storedKey = null, clientSignature = null,\n                clientProof = null, serverKey = null, serverSignature = null;\n\n        try {\n            // HTTP SCRAM: no CB -> c=biws\n            final String clientFinalNoProof = \"c=\" + C_BIND_B64 + \",r=\" + this.serverNonce;\n            final String authMessage = this.clientFirstBare + \",\" + this.serverFirstRaw + \",\" + clientFinalNoProof;\n\n            salted = hiPBKDF2(this.password, this.salt, this.iterations, 32);\n            clientKey = hmac(salted, \"Client Key\");\n            storedKey = sha256(clientKey);\n            clientSignature = hmac(storedKey, authMessage);\n            clientProof = xor(clientKey, clientSignature);\n            final String pB64 = B64.encodeToString(clientProof);\n\n            serverKey = hmac(salted, \"Server Key\");\n            serverSignature = hmac(serverKey, authMessage);\n\n            // Stash expected v (raw) for constant-time check on 2xx\n            zeroAndClearExpectedV();\n            this.expectedV = serverSignature.clone();\n\n            final String clientFinal = clientFinalNoProof + \",p=\" + pB64;\n            final String data = stringToB64(clientFinal);\n\n            final StringBuilder sb = new StringBuilder(64);\n            sb.append(StandardAuthScheme.SCRAM_SHA_256).append(' ');\n            if (this.sid != null) {\n                sb.append(\"sid=\").append(quoteParam(this.sid)).append(\", \");\n            }\n            sb.append(\"data=\").append(quoteParam(data)); // quoted\n\n            this.state = State.CLIENT_FINAL_SENT;\n            this.complete = false;\n            return sb.toString();\n        } catch (final GeneralSecurityException e) {\n            this.state = State.FAILED;\n            throw new AuthenticationException(\"SCRAM crypto failure\", e);\n        } finally {\n            if (this.password != null) {\n                Arrays.fill(this.password, '\\0');\n                this.password = null;\n            }\n            zero(salted);\n            zero(clientKey);\n            zero(storedKey);\n            zero(clientSignature);\n            zero(clientProof);\n            zero(serverKey);\n            // clone held in expectedV\n            zero(serverSignature);\n        }\n    }\n\n    private static void zero(final byte[] a) {\n        if (a != null) {\n            Arrays.fill(a, (byte) 0);\n        }\n    }\n\n    private void zeroAndClearExpectedV() {\n        if (this.expectedV != null) {\n            zero(this.expectedV);\n            this.expectedV = null;\n        }\n    }\n\n    private static Map<String, String> toParamMap(final List<NameValuePair> pairs) {\n        final Map<String, String> m = new HashMap<>();\n        if (pairs != null) {\n            for (final NameValuePair p : pairs) {\n                if (p != null && p.getName() != null) {\n                    m.put(p.getName().toLowerCase(Locale.ROOT), p.getValue());\n                }\n            }\n        }\n        return m;\n    }\n\n    // Parse \"k=v(,k=v)*\" with RFC 5802 escapes: \"=2C\"/\"=2c\" -> \",\", \"=3D\"/\"=3d\" -> \"=\"\n    private static Map<String, String> parseAttrs(final String s) throws MalformedChallengeException {\n        final Map<String, String> out = new LinkedHashMap<>();\n        int i = 0;\n        while (i < s.length()) {\n            if (i + 2 > s.length() || s.charAt(i + 1) != '=') {\n                throw new MalformedChallengeException(\"Bad SCRAM attr at index \" + i);\n            }\n            final String k = String.valueOf(s.charAt(i));\n            i += 2;\n            final StringBuilder v = new StringBuilder();\n            while (i < s.length()) {\n                final char c = s.charAt(i);\n                if (c == ',') {\n                    i++;\n                    break;\n                }\n                if (c == '=' && i + 2 < s.length()) {\n                    final String esc = s.substring(i, i + 3);\n                    if (\"=2C\".equalsIgnoreCase(esc)) {\n                        v.append(',');\n                        i += 3;\n                        continue;\n                    }\n                    if (\"=3D\".equalsIgnoreCase(esc)) {\n                        v.append('=');\n                        i += 3;\n                        continue;\n                    }\n                }\n                v.append(c);\n                i++;\n            }\n            out.put(k, v.toString());\n        }\n        return out;\n    }\n\n    private String genNonce() {\n        final byte[] buf = new byte[16];\n        this.secureRandom.nextBytes(buf);\n        final StringBuilder sb = new StringBuilder(buf.length * 2);\n        for (final byte b : buf) {\n            final int v = b & 0xff;\n            if (v < 0x10) {\n                sb.append('0');\n            }\n            sb.append(Integer.toHexString(v));\n        }\n        return sb.toString();\n    }\n\n    private static String escapeUser(final String user) {\n        if (user == null) {\n            // Defensive for tests that skip isResponseReady() before client-first\n            return \"\";\n        }\n        final StringBuilder sb = new StringBuilder(user.length() + 8);\n        for (int i = 0; i < user.length(); i++) {\n            final char c = user.charAt(i);\n            if (c == ',') {\n                sb.append(\"=2C\");\n            } else if (c == '=') {\n                sb.append(\"=3D\");\n            } else {\n                sb.append(c);\n            }\n        }\n        return sb.toString();\n    }\n\n    private static String quoteParam(final String v) {\n        if (v == null) {\n            return \"\\\"\\\"\";\n        }\n        final StringBuilder sb = new StringBuilder(v.length() + 2);\n        sb.append('\"');\n        for (int i = 0; i < v.length(); i++) {\n            final char c = v.charAt(i);\n            if (c == '\\\\' || c == '\"') {\n                sb.append('\\\\');\n            }\n            sb.append(c);\n        }\n        sb.append('\"');\n        return sb.toString();\n    }\n\n    private static byte[] hiPBKDF2(final char[] password, final byte[] salt, final int iterations, final int dkLen)\n            throws GeneralSecurityException {\n        final PBEKeySpec spec = new PBEKeySpec(password, salt, iterations, dkLen * 8);\n        return SecretKeyFactory.getInstance(\"PBKDF2WithHmacSHA256\").generateSecret(spec).getEncoded();\n    }\n\n    private static byte[] hmac(final byte[] key, final String msg) throws GeneralSecurityException {\n        final Mac mac = Mac.getInstance(\"HmacSHA256\");\n        mac.init(new SecretKeySpec(key, \"HmacSHA256\"));\n        return mac.doFinal(msg.getBytes(StandardCharsets.UTF_8));\n    }\n\n    private static byte[] sha256(final byte[] in) throws GeneralSecurityException {\n        return MessageDigest.getInstance(\"SHA-256\").digest(in);\n    }\n\n    private static byte[] xor(final byte[] a, final byte[] b) {\n        final int len = Math.min(a.length, b.length);\n        final byte[] out = new byte[len];\n        for (int i = 0; i < len; i++) {\n            out[i] = (byte) (a[i] ^ b[i]);\n        }\n        return out;\n    }\n\n    private static String stringToB64(final String s) {\n        return B64.encodeToString(s.getBytes(StandardCharsets.UTF_8));\n    }\n\n    private static String b64ToString(final String b64) throws MalformedChallengeException {\n        try {\n            return new String(B64D.decode(b64), StandardCharsets.UTF_8);\n        } catch (final IllegalArgumentException e) {\n            throw new MalformedChallengeException(\"Bad base64 'data' value\", e);\n        }\n    }\n\n    private static final class SimplePrincipal implements Principal {\n        private final String name;\n\n        private SimplePrincipal(final String name) {\n            this.name = name;\n        }\n\n        @Override\n        public String getName() {\n            return this.name;\n        }\n\n        @Override\n        public String toString() {\n            return this.name;\n        }\n    }\n\n}\n","numLines":685,"startLine":1,"totalLines":685}}}
