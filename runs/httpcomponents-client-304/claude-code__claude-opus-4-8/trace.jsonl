string(i, eq);\n91\t            i = eq + 1;\n92\t            final StringBuilder v = new StringBuilder();\n93\t            while (i < s.length()) {\n94\t                final char c = s.charAt(i);\n95\t                if (c == ',') {\n96\t                    i++;\n97\t                    break;\n98\t                }\n99\t                v.append(c);\n100\t                i++;\n101\t            }\n102\t            m.put(k, v.toString());\n103\t        }\n104\t        return m;\n105\t    }\n106\t\n107\t    static Map<String, String> splitHeader(final String header) {\n108\t        // \"SCRAM-SHA-256 realm=\"...\", data=\"...\"\" -> name/value map (lowercase keys)\n109\t        final int sp = header.indexOf(' ');\n110\t        final String params = header.substring(sp + 1);\n111\t        final Map<String, String> map = new HashMap<>();\n112\t        for (String part : params.split(\",\")) {\n113\t            part = part.trim();\n114\t            final int eq = part.indexOf('=');\n115\t            if (eq > 0) {\n116\t                final String k = part.substring(0, eq).toLowerCase(Locale.ROOT);\n117\t                String v = part.substring(eq + 1);\n118\t                if (v.length() >= 2 && v.startsWith(\"\\\"\") && v.endsWith(\"\\\"\")) {\n119\t                    v = v.substring(1, v.length() - 1);\n120\t                }\n121\t                map.put(k, v);\n122\t            }\n123\t        }\n124\t        return map;\n125\t    }\n126\t\n127\t    static byte[] pbkdf2(final char[] password, final byte[] salt, final int iter, final int dkLen)\n128\t            throws GeneralSecurityException {\n129\t        final PBEKeySpec spec = new PBEKeySpec(password, salt, iter, dkLen * 8);\n130\t        return SecretKeyFactory.getInstance(\"PBKDF2WithHmacSHA256\").generateSecret(spec).getEncoded();\n131\t    }\n132\t\n133\t    static byte[] hmac(final byte[] key, final String msg) throws GeneralSecurityException {\n134\t        final Mac mac = Mac.getInstance(\"HmacSHA256\