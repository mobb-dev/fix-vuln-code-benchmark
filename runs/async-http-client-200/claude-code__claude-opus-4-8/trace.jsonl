{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PHwTQCAnB6kbvRiF9Q59Kj","type":"tool_result","content":"1\t/*\n2\t *    Copyright (c) 2015-2026 AsyncHttpClient Project. All rights reserved.\n3\t *\n4\t *    Licensed under the Apache License, Version 2.0 (the \"License\");\n5\t *    you may not use this file except in compliance with the License.\n6\t *    You may obtain a copy of the License at\n7\t *\n8\t *        http://www.apache.org/licenses/LICENSE-2.0\n9\t *\n10\t *    Unless required by applicable law or agreed to in writing, software\n11\t *    distributed under the License is distributed on an \"AS IS\" BASIS,\n12\t *    WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13\t *    See the License for the specific language governing permissions and\n14\t *    limitations under the License.\n15\t */\n16\tpackage org.asynchttpclient;\n17\t\n18\timport com.sun.net.httpserver.HttpServer;\n19\timport org.junit.jupiter.api.AfterAll;\n20\timport org.junit.jupiter.api.BeforeAll;\n21\timport org.junit.jupiter.api.Test;\n22\t\n23\timport java.net.InetSocketAddress;\n24\timport java.nio.charset.StandardCharsets;\n25\timport java.util.concurrent.TimeUnit;\n26\timport java.util.concurrent.atomic.AtomicReference;\n27\t\n28\timport static org.asynchttpclient.Dsl.basicAuthRealm;\n29\timport static org.junit.jupiter.api.Assertions.assertEquals;\n30\timport static org.junit.jupiter.api.Assertions.assertNull;\n31\t\n32\t/**\n33\t * Tests for credential stripping on cross-domain redirects and HTTPS-to-HTTP downgrades.\n34\t * Verifies that Authorization headers and Realm credentials are not leaked to different origins.\n35\t */\n36\tpublic class RedirectCredentialSecurityTest {\n37\t\n38\t    private static HttpServer serverA;\n39\t    private static HttpServer serverB;\n40\t    private static HttpServer serverC;\n41\t    private static int portA;\n42\t    private static int portB;\n43\t    private static int portC;\n44\t    private static final AtomicReference<String> lastAuthHeaderOnA = new AtomicReference<>();\n45\t    private static final AtomicReference<String> lastAuthHeaderOnB = new AtomicReference<>();\n46\t    private static final AtomicReference<String> authAtChainStep2 = new AtomicReference<>();\n47\t    private static final AtomicReference<String> authOnBounceBack = new AtomicReference<>();\n48\t    private static final AtomicReference<String> authOn307Target = new AtomicReference<>();\n49\t    private static final AtomicReference<String> bodyOn307Target = new AtomicReference<>();\n50\t    private static final AtomicReference<String> authOn308Target = new AtomicReference<>();\n51\t    private static final AtomicReference<String> bodyOn308Target = new AtomicReference<>();\n52\t\n53\t    @BeforeAll\n54\t    public static void startServers() throws Exception {\n55\t        // Server A: the \"origin\" server that issues redirects\n56\t        serverA = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n57\t        portA = serverA.getAddress().getPort();\n58\t\n59\t        // Server B: the \"target\" server that receives redirected requests (different port = different origin)\n60\t        serverB = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n61\t        portB = serverB.getAddress().getPort();\n62\t\n63\t        // Server C: a third server for multi-hop redirect chains\n64\t        serverC = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n65\t        portC = serverC.getAddress().getPort();\n66\t\n67\t        // Server A endpoints\n68\t        serverA.createContext(\"/redirect-to-b\", exchange -> {\n69\t            lastAuthHeaderOnA.set(exchange.getRequestHeaders().getFirst(\"Authorization\"));\n70\t            exchange.getResponseHeaders().add(\"Location\", \"http://127.0.0.1:\" + portB + \"/target\");\n71\t            exchange.sendResponseHeaders(302, -1);\n72\t            exchange.close();\n73\t        });\n74\t\n75\t        serverA.createContext(\"/redirect-same-origin\", exchange -> {\n76\t            lastAuthHeaderOnA.set(exchange.getRequestHeaders().getFirst(\"Authorization\"));\n77\t            exchange.getResponseHeaders().add(\"Location\", \"http://127.0.0.1:\" + portA + \"/final\");\n78\t            exchange.sendResponseHeaders(302, -1);\n79\t            exchange.close();\n80\t        });\n81\t\n82\t        serverA.createContext(\"/final\", exchange -> {\n83\t            lastAuthHeaderOnA.set(exchange.getRequestHeaders().getFirst(\"Authorization\"));\n84\t            exchange.sendResponseHeaders(200, 0);\n85\t            exchange.getResponseBody().close();\n86\t            exchange.close();\n87\t        });\n88\t\n89\t        // Server B endpoints\n90\t        serverB.createContext(\"/target\", exchange -> {\n91\t            lastAuthHeaderOnB.set(exchange.getRequestHeaders().getFirst(\"Authorization\"));\n92\t            exchange.sendResponseHeaders(200, 0);\n93\t            exchange.getResponseBody().close();\n94\t            exchange.close();\n95\t        });\n96\t\n97\t        // Multi-hop: A → A (same-origin) → B (cross-domain)\n98\t        serverA.createContext(\"/chain-same-then-cross\", exchange -> {\n99\t            exchange.getResponseHeaders().add(\"Location\", \"http://127.0.0.1:\" + portA + \"/chain-step2\");\n100\t            exchange.sendResponseHeaders(302, -1);\n101\t            exchange.close();\n102\t        });\n103\t\n104\t        serverA.createContext(\"/chain-step2\", exchange -> {\n105\t            authAtChainStep2.set(exchange.getRequestHeaders().getFirst(\"Authorization\"));\n106\t            exchange.getResponseHeaders().add(\"Location\", \"http://127.0.0.1:\" + portB + \"/target\");\n107\t            exchange.sendResponseHeaders(302, -1);\n108\t            exchange.close();\n109\t        });\n110\t\n111\t        // Multi-hop: A → B (cross-domain, credentials stripped) → C (credentials stay stripped)\n112\t        serverA.createContext(\"/chain-cross-and-back\", exchange -> {\n113\t            exchange.getResponseHeaders().add(\"Location\", \"http://127.0.0.1:\" + portB + \"/bounce-to-c\");\n114\t            exchange.sendResponseHeaders(302, -1);\n115\t            exchange.close();\n116\t        });\n117\t\n118\t        serverB.createContext(\"/bounce-to-c\", exchange -> {\n119\t            exchange.getResponseHeaders().add(\"Location\", \"http://127.0.0.1:\" + portC + \"/chain-final\");\n120\t            exchange.sendResponseHeaders(302, -1);\n121\t            exchange.close();\n122\t        });\n123\t\n124\t        serverC.createContext(\"/chain-final\", exchange -> {\n125\t            authOnBounceBack.set(exchange.getRequestHeaders().getFirst(\"Authorization\"));\n126\t            exchange.sendResponseHeaders(200, 0);\n127\t            exchange.getResponseBody().close();\n128\t            exchange.close();\n129\t        });\n130\t\n131\t        // 307 Temporary Redirect: A → B (body preserved, auth stripped)\n132\t        serverA.createContext(\"/redirect-307-to-b\", exchange -> {\n133\t            exchange.getResponseHeaders().add(\"Location\", \"http://127.0.0.1:\" + portB + \"/target-307\");\n134\t            exchange.sendResponseHeaders(307, -1);\n135\t            exchange.close();\n136\t        });\n137\t\n138\t        serverB.createContext(\"/target-307\", exchange -> {\n139\t            authOn307Target.set(exchange.getRequestHeaders().getFirst(\"Authorization\"));\n140\t            bodyOn307Target.set(new String(exchange.getRequestBody().readAllBytes(), StandardCharsets.UTF_8));\n141\t            exchange.sendResponseHeaders(200, 0);\n142\t            exchange.getResponseBody().close();\n143\t            exchange.close();\n144\t        });\n145\t\n146\t        // 308 Permanent Redirect: A → B (body preserved, auth stripped)\n147\t        serverA.createContext(\"/redirect-308-to-b\", exchange -> {\n148\t            exchange.getResponseHeaders().add(\"Location\", \"http://127.0.0.1:\" + portB + \"/target-308\");\n149\t            exchange.sendResponseHeaders(308, -1);\n150\t            exchange.close();\n151\t        });\n152\t\n153\t        serverB.createContext(\"/target-308\", exchange -> {\n154\t            authOn308Target.set(exchange.getRequestHeaders().getFirst(\"Authorization\"));\n155\t            bodyOn308Target.set(new String(exchange.getRequestBody().readAllBytes(), StandardCharsets.UTF_8));\n156\t            exchange.sendResponseHeaders(200, 0);\n157\t            exchange.getResponseBody().close();\n158\t            exchange.close();\n159\t        });\n160\t\n161\t        serverA.start();\n162\t        serverB.start();\n163\t        serverC.start();\n164\t    }\n165\t\n166\t    @AfterAll\n167\t    public static void stopServers() {\n168\t        serverA.stop(0);\n169\t        serverB.stop(0);\n170\t        serverC.stop(0);\n171\t    }\n172\t\n173\t    /**\n174\t     * Cross-domain redirect (different port) must strip Authorization header.\n175\t     */\n176\t    @Test\n177\t    void crossDomainRedirectStripsAuthHeader() throws Exception {\n178\t        DefaultAsyncHttpClientConfig config = new DefaultAsyncHttpClientConfig.Builder()\n179\t                .setFollowRedirect(true)\n180\t                .build();\n181\t        try (DefaultAsyncHttpClient client = new DefaultAsyncHttpClient(config)) {\n182\t            lastAuthHeaderOnA.set(null);\n183\t            lastAuthHeaderOnB.set(null);\n184\t\n185\t            client.prepareGet(\"http://127.0.0.1:\" + portA + \"/redirect-to-b\")\n186\t                    .setHeader(\"Authorization\", \"Bearer secret-token\")\n187\t                    .execute()\n188\t                    .get(5, TimeUnit.SECONDS);\n189\t\n190\t            // Auth header should be present on the original request to server A\n191\t            assertEquals(\"Bearer secret-token\", lastAuthHeaderOnA.get(),\n192\t                    \"Authorization header should be present on original request\");\n193\t            // Auth header must NOT be forwarded to the cross-domain target (server B)\n194\t            assertNull(lastAuthHeaderOnB.get(),\n195\t                    \"Authorization header must be stripped on cross-domain redirect\");\n196\t        }\n197\t    }\n198\t\n199\t    /**\n200\t     * Same-origin redirect (same host and port) should preserve Authorization header.\n201\t     */\n202\t    @Test\n203\t    void sameOriginRedirectPreservesAuthHeader() throws Exception {\n204\t        DefaultAsyncHttpClientConfig config = new DefaultAsyncHttpClientConfig.Builder()\n205\t                .setFollowRedirect(true)\n206\t                .build();\n207\t        try (DefaultAsyncHttpClient client = new DefaultAsyncHttpClient(config)) {\n208\t            lastAuthHeaderOnA.set(null);\n209\t\n210\t            client.prepareGet(\"http://127.0.0.1:\" + portA + \"/redirect-same-origin\")\n211\t                    .setHeader(\"Authorization\", \"Bearer secret-token\")\n212\t                    .execute()\n213\t                    .get(5, TimeUnit.SECONDS);\n214\t\n215\t            // Auth header should still be present after same-origin redirect\n216\t            assertEquals(\"Bearer secret-token\", lastAuthHeaderOnA.get(),\n217\t                    \"Authorization header should be preserved on same-origin redirect\");\n218\t        }\n219\t    }\n220\t\n221\t    /**\n222\t     * Cross-domain redirect must strip Proxy-Authorization header too.\n223\t     */\n224\t    @Test\n225\t    void crossDomainRedirectStripsProxyAuthHeader() throws Exception {\n226\t        DefaultAsyncHttpClientConfig config = new DefaultAsyncHttpClientConfig.Builder()\n227\t                .setFollowRedirect(true)\n228\t                .build();\n229\t        try (DefaultAsyncHttpClient client = new DefaultAsyncHttpClient(config)) {\n230\t            lastAuthHeaderOnB.set(null);\n231\t\n232\t            // We capture Proxy-Authorization on server B using a custom handler\n233\t            final AtomicReference<String> proxyAuthOnB = new AtomicReference<>();\n234\t            serverB.createContext(\"/target-proxy\", exchange -> {\n235\t                proxyAuthOnB.set(exchange.getRequestHeaders().getFirst(\"Proxy-Authorization\"));\n236\t                exchange.sendResponseHeaders(200, 0);\n237\t                exchange.getResponseBody().close();\n238\t                exchange.close();\n239\t            });\n240\t            serverA.createContext(\"/redirect-to-b-proxy\", exchange -> {\n241\t                exchange.getResponseHeaders().add(\"Location\", \"http://127.0.0.1:\" + portB + \"/target-proxy\");\n242\t                exchange.sendResponseHeaders(302, -1);\n243\t                exchange.close();\n244\t            });\n245\t\n246\t            client.prepareGet(\"http://127.0.0.1:\" + portA + \"/redirect-to-b-proxy\")\n247\t                    .setHeader(\"Proxy-Authorization\", \"Basic cHJveHk6cGFzcw==\")\n248\t                    .execute()\n249\t                    .get(5, TimeUnit.SECONDS);\n250\t\n251\t            assertNull(proxyAuthOnB.get(),\n252\t                    \"Proxy-Authorization header must be stripped on cross-domain redirect\");\n253\t        }\n254\t    }\n255\t\n256\t    /**\n257\t     * Realm-based BASIC auth credentials must NOT be propagated on cross-domain redirects.\n258\t     * This tests that the Realm object is cleared, preventing credential regeneration\n259\t     * via NettyRequestFactory.\n260\t     */\n261\t    @Test\n262\t    void crossDomainRedirectDoesNotPropagateRealm() throws Exception {\n263\t        DefaultAsyncHttpClientConfig config = new DefaultAsyncHttpClientConfig.Builder()\n264\t                .setFollowRedirect(true)\n265\t                .build();\n266\t        try (DefaultAsyncHttpClient client = new DefaultAsyncHttpClient(config)) {\n267\t            lastAuthHeaderOnB.set(null);\n268\t\n269\t            client.prepareGet(\"http://127.0.0.1:\" + portA + \"/redirect-to-b\")\n270\t                    .setRealm(basicAuthRealm(\"user\", \"password\").setUsePreemptiveAuth(true).build())\n271\t                    .execute()\n272\t                    .get(5, TimeUnit.SECONDS);\n273\t\n274\t            // The Realm-generated Authorization header must NOT appear on the cross-domain target\n275\t            assertNull(lastAuthHeaderOnB.get(),\n276\t                    \"Realm-based credentials must not be propagated on cross-domain redirect\");\n277\t        }\n278\t    }\n279\t\n280\t    /**\n281\t     * Realm bypass is closed: even with stripAuthorizationOnRedirect=true on a same-origin redirect,\n282\t     * the Realm credential regeneration must be prevented (no Authorization header on target).\n283\t     */\n284\t    @Test\n285\t    void stripAuthorizationOnRedirectAlsoStripsRealm() throws Exception {\n286\t        DefaultAsyncHttpClientConfig config = new DefaultAsyncHttpClientConfig.Builder()\n287\t                .setFollowRedirect(true)\n288\t                .setStripAuthorizationOnRedirect(true)\n289\t                .build();\n290\t        try (DefaultAsyncHttpClient client = new DefaultAsyncHttpClient(config)) {\n291\t            lastAuthHeaderOnA.set(null);\n292\t\n293\t            client.prepareGet(\"http://127.0.0.1:\" + portA + \"/redirect-same-origin\")\n294\t                    .setRealm(basicAuthRealm(\"user\", \"password\").setUsePreemptiveAuth(true).build())\n295\t                    .execute()\n296\t                    .get(5, TimeUnit.SECONDS);\n297\t\n298\t            // Even on same-origin, with stripAuthorizationOnRedirect=true, the Realm-regenerated\n299\t            // Authorization header must NOT appear (this was the bypass bug)\n300\t            assertNull(lastAuthHeaderOnA.get(),\n301\t                    \"stripAuthorizationOnRedirect=true must also prevent Realm-based credential regeneration\");\n302\t        }\n303\t    }\n304\t\n305\t    /**\n306\t     * Same-origin redirect should preserve Realm-based credentials when stripping is not enabled.\n307\t     */\n308\t    @Test\n309\t    void sameOriginRedirectPreservesRealmCredentials() throws Exception {\n310\t        DefaultAsyncHttpClientConfig config = new DefaultAsyncHttpClientConfig.Builder()\n311\t                .setFollowRedirect(true)\n312\t                .build();\n313\t        try (DefaultAsyncHttpClient client = new DefaultAsyncHttpClient(config)) {\n314\t            lastAuthHeaderOnA.set(null);\n315\t\n316\t            client.prepareGet(\"http://127.0.0.1:\" + portA + \"/redirect-same-origin\")\n317\t                    .setRealm(basicAuthRealm(\"user\", \"password\").setUsePreemptiveAuth(true).build())\n318\t                    .execute()\n319\t                    .get(5, TimeUnit.SECONDS);\n320\t\n321\t            // On same-origin, Realm credentials should be preserved\n322\t            assertEquals(\"Basic dXNlcjpwYXNzd29yZA==\", lastAuthHeaderOnA.get(),\n323\t                    \"Realm-based credentials should be preserved on same-origin redirect\");\n324\t        }\n325\t    }\n326\t\n327\t    /**\n328\t     * Multi-hop redirect: A → A (same-origin) → B (cross-domain).\n329\t     * Credentials should survive the same-origin hop but be stripped on the cross-domain hop.\n330\t     */\n331\t    @Test\n332\t    void multiHopSameOriginThenCrossDomainStripsCredentials() throws Exception {\n333\t        DefaultAsyncHttpClientConfig config = new DefaultAsyncHttpClientConfig.Builder()\n334\t                .setFollowRedirect(true)\n335\t                .build();\n336\t        try (DefaultAsyncHttpClient client = new DefaultAsyncHttpClient(config)) {\n337\t            authAtChainStep2.set(null);\n338\t            lastAuthHeaderOnB.set(null);\n339\t\n340\t            client.prepareGet(\"http://127.0.0.1:\" + portA + \"/chain-same-then-cross\")\n341\t                    .setHeader(\"Authorization\", \"Bearer secret-token\")\n342\t                    .execute()\n343\t                    .get(5, TimeUnit.SECONDS);\n344\t\n345\t            // Credentials should survive the same-origin intermediate hop (A → A)\n346\t            assertEquals(\"Bearer secret-token\", authAtChainStep2.get(),\n347\t                    \"Authorization header should be preserved on same-origin intermediate redirect\");\n348\t            // Credentials must be stripped on the final cross-domain hop (A → B)\n349\t            assertNull(lastAuthHeaderOnB.get(),\n350\t                    \"Authorization header must be stripped on cross-domain hop in redirect chain\");\n351\t        }\n352\t    }\n353\t\n354\t    /**\n355\t     * Multi-hop redirect: A → B (cross-domain) → C (another domain).\n356\t     * Once credentials are stripped at the first cross-domain hop, they must not reappear\n357\t     * on subsequent hops even if the Realm was originally set.\n358\t     */\n359\t    @Test\n360\t    void multiHopCredentialsStayStrippedAfterCrossDomain() throws Exception {\n361\t        DefaultAsyncHttpClientConfig config = new DefaultAsyncHttpClientConfig.Builder()\n362\t                .setFollowRedirect(true)\n363\t                .build();\n364\t        try (DefaultAsyncHttpClient client = new DefaultAsyncHttpClient(config)) {\n365\t            authOnBounceBack.set(null);\n366\t\n367\t            client.prepareGet(\"http://127.0.0.1:\" + portA + \"/chain-cross-and-back\")\n368\t                    .setRealm(basicAuthRealm(\"user\", \"password\").setUsePreemptiveAuth(true).build())\n369\t                    .execute()\n370\t                    .get(5, TimeUnit.SECONDS);\n371\t\n372\t            // Credentials were stripped at A → B; they must not reappear at B → C\n373\t            assertNull(authOnBounceBack.get(),\n374\t                    \"Credentials must not reappear after being stripped at a cross-domain hop\");\n375\t        }\n376\t    }\n377\t\n378\t    /**\n379\t     * 307 Temporary Redirect cross-domain: body is preserved but Authorization is stripped.\n380\t     */\n381\t    @Test\n382\t    void redirect307CrossDomainStripsAuthButPreservesBody() throws Exception {\n383\t        DefaultAsyncHttpClientConfig config = new DefaultAsyncHttpClientConfig.Builder()\n384\t                .setFollowRedirect(true)\n385\t                .build();\n386\t        try (DefaultAsyncHttpClient client = new DefaultAsyncHttpClient(config)) {\n387\t            authOn307Target.set(null);\n388\t            bodyOn307Target.set(null);\n389\t\n390\t            client.preparePost(\"http://127.0.0.1:\" + portA + \"/redirect-307-to-b\")\n391\t                    .setHeader(\"Authorization\", \"Bearer secret-token\")\n392\t                    .setBody(\"request-body-content\")\n393\t                    .execute()\n394\t                    .get(5, TimeUnit.SECONDS);\n395\t\n396\t            assertNull(authOn307Target.get(),\n397\t                    \"Authorization header must be stripped on cross-domain 307 redirect\");\n398\t            assertEquals(\"request-body-content\", bodyOn307Target.get(),\n399\t                    \"Request body must be preserved on 307 redirect\");\n400\t        }\n401\t    }\n402\t\n403\t    /**\n404\t     * 308 Permanent Redirect cross-domain: body is preserved but Authorization is stripped.\n405\t     */\n406\t    @Test\n407\t    void redirect308CrossDomainStripsAuthButPreservesBody() throws Exception {\n408\t        DefaultAsyncHttpClientConfig config = new DefaultAsyncHttpClientConfig.Builder()\n409\t                .setFollowRedirect(true)\n410\t                .build();\n411\t        try (DefaultAsyncHttpClient client = new DefaultAsyncHttpClient(config)) {\n412\t            authOn308Target.set(null);\n413\t            bodyOn308Target.set(null);\n414\t\n415\t            client.preparePost(\"http://127.0.0.1:\" + portA + \"/redirect-308-to-b\")\n416\t                    .setHeader(\"Authorization\", \"Bearer secret-token\")\n417\t                    .setBody(\"request-body-content\")\n418\t                    .execute()\n419\t                    .get(5, TimeUnit.SECONDS);\n420\t\n421\t            assertNull(authOn308Target.get(),\n422\t                    \"Authorization header must be stripped on cross-domain 308 redirect\");\n423\t            assertEquals(\"request-body-content\", bodyOn308Target.get(),\n424\t                    \"Request body must be preserved on 308 redirect\");\n425\t        }\n426\t    }\n427\t}\n428\t"}]},"parent_tool_use_id":null,"session_id":"9e10c5bb-b262-42b1-82a9-825bdddbbe96","uuid":"dc7e9def-5775-42aa-a71a-0f22c45765b1","timestamp":"2026-06-30T19:00:56.689Z","tool_use_result":{"type":"text","file":{"filePath":"/work/client/src/test/java/org/asynchttpclient/RedirectCredentialSecurityTest.java","content":"/*\n *    Copyright (c) 2015-2026 AsyncHttpClient Project. All rights reserved.\n *\n *    Licensed under the Apache License, Version 2.0 (the \"License\");\n *    you may not use this file except in compliance with the License.\n *    You may obtain a copy of the License at\n *\n *        http://www.apache.org/licenses/LICENSE-2.0\n *\n *    Unless required by applicable law or agreed to in writing, software\n *    distributed under the License is distributed on an \"AS IS\" BASIS,\n *    WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n *    See the License for the specific language governing permissions and\n *    limitations under the License.\n */\npackage org.asynchttpclient;\n\nimport com.sun.net.httpserver.HttpServer;\nimport org.junit.jupiter.api.AfterAll;\nimport org.junit.jupiter.api.BeforeAll;\nimport org.junit.jupiter.api.Test;\n\nimport java.net.InetSocketAddress;\nimport java.nio.charset.StandardCharsets;\nimport java.util.concurrent.TimeUnit;\nimport java.util.concurrent.atomic.AtomicReference;\n\nimport static org.asynchttpclient.Dsl.basicAuthRealm;\nimport static org.junit.jupiter.api.Assertions.assertEquals;\nimport static org.junit.jupiter.api.Assertions.assertNull;\n\n/**\n * Tests for credential stripping on cross-domain redirects and HTTPS-to-HTTP downgrades.\n * Verifies that Authorization headers and Realm credentials are not leaked to different origins.\n */\npublic class RedirectCredentialSecurityTest {\n\n    private static HttpServer serverA;\n    private static HttpServer serverB;\n    private static HttpServer serverC;\n    private static int portA;\n    private static int portB;\n    private static int portC;\n    private static final AtomicReference<String> lastAuthHeaderOnA = new AtomicReference<>();\n    private static final AtomicReference<String> lastAuthHeaderOnB = new AtomicReference<>();\n    private static final AtomicReference<String> authAtChainStep2 = new AtomicReference<>();\n    private static final AtomicReference<String> authOnBounceBack = new AtomicReference<>();\n    private static final AtomicReference<String> authOn307Target = new AtomicReference<>();\n    private static final AtomicReference<String> bodyOn307Target = new AtomicReference<>();\n    private static final AtomicReference<String> authOn308Target = new AtomicReference<>();\n    private static final AtomicReference<String> bodyOn308Target = new AtomicReference<>();\n\n    @BeforeAll\n    public static void startServers() throws Exception {\n        // Server A: the \"origin\" server that issues redirects\n        serverA = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        portA = serverA.getAddress().getPort();\n\n        // Server B: the \"target\" server that receives redirected requests (different port = different origin)\n        serverB = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        portB = serverB.getAddress().getPort();\n\n        // Server C: a third server for multi-hop redirect chains\n        serverC = HttpServer.create(new InetSocketAddress(\"127.0.0.1\", 0), 0);\n        portC = serverC.getAddress().getPort();\n\n        // Server A endpoints\n        serverA.createContext(\"/redirect-to-b\", exchange -> {\n            lastAuthHeaderOnA.set(exchange.getRequestHeaders().getFirst(\"Authorization\"));\n            exchange.getResponseHeaders().add(\"Location\", \"http://127.0.0.1:\" + portB + \"/target\");\n            exchange.sendResponseHeaders(302, -1);\n            exchange.close();\n        });\n\n        serverA.createContext(\"/redirect-same-origin\", exchange -> {\n            lastAuthHeaderOnA.set(exchange.getRequestHeaders().getFirst(\"Authorization\"));\n            exchange.getResponseHeaders().add(\"Location\", \"http://127.0.0.1:\" + portA + \"/final\");\n            exchange.sendResponseHeaders(302, -1);\n            exchange.close();\n        });\n\n        serverA.createContext(\"/final\", exchange -> {\n            lastAuthHeaderOnA.set(exchange.getRequestHeaders().getFirst(\"Authorization\"));\n            exchange.sendResponseHeaders(200, 0);\n            exchange.getResponseBody().close();\n            exchange.close();\n        });\n\n        // Server B endpoints\n        serverB.createContext(\"/target\", exchange -> {\n            lastAuthHeaderOnB.set(exchange.getRequestHeaders().getFirst(\"Authorization\"));\n            exchange.sendResponseHeaders(200, 0);\n            exchange.getResponseBody().close();\n            exchange.close();\n        });\n\n        // Multi-hop: A → A (same-origin) → B (cross-domain)\n        serverA.createContext(\"/chain-same-then-cross\", exchange -> {\n            exchange.getResponseHeaders().add(\"Location\", \"http://127.0.0.1:\" + portA + \"/chain-step2\");\n            exchange.sendResponseHeaders(302, -1);\n            exchange.close();\n        });\n\n        serverA.createContext(\"/chain-step2\", exchange -> {\n            authAtChainStep2.set(exchange.getRequestHeaders().getFirst(\"Authorization\"));\n            exchange.getResponseHeaders().add(\"Location\", \"http://127.0.0.1:\" + portB + \"/target\");\n            exchange.sendResponseHeaders(302, -1);\n            exchange.close();\n        });\n\n        // Multi-hop: A → B (cross-domain, credentials stripped) → C (credentials stay stripped)\n        serverA.createContext(\"/chain-cross-and-back\", exchange -> {\n            exchange.getResponseHeaders().add(\"Location\", \"http://127.0.0.1:\" + portB + \"/bounce-to-c\");\n            exchange.sendResponseHeaders(302, -1);\n            exchange.close();\n        });\n\n        serverB.createContext(\"/bounce-to-c\", exchange -> {\n            exchange.getResponseHeaders().add(\"Location\", \"http://127.0.0.1:\" + portC + \"/chain-final\");\n            exchange.sendResponseHeaders(302, -1);\n            exchange.close();\n        });\n\n        serverC.createContext(\"/chain-final\", exchange -> {\n            authOnBounceBack.set(exchange.getRequestHeaders().getFirst(\"Authorization\"));\n            exchange.sendResponseHeaders(200, 0);\n            exchange.getResponseBody().close();\n            exchange.close();\n        });\n\n        // 307 Temporary Redirect: A → B (body preserved, auth stripped)\n        serverA.createContext(\"/redirect-307-to-b\", exchange -> {\n            exchange.getResponseHeaders().add(\"Location\", \"http://127.0.0.1:\" + portB + \"/target-307\");\n            exchange.sendResponseHeaders(307, -1);\n            exchange.close();\n        });\n\n        serverB.createContext(\"/target-307\", exchange -> {\n            authOn307Target.set(exchange.getRequestHeaders().getFirst(\"Authorization\"));\n            bodyOn307Target.set(new String(exchange.getRequestBody().readAllBytes(), StandardCharsets.UTF_8));\n            exchange.sendResponseHeaders(200, 0);\n            exchange.getResponseBody().close();\n            exchange.close();\n        });\n\n        // 308 Permanent Redirect: A → B (body preserved, auth stripped)\n        serverA.createContext(\"/redirect-308-to-b\", exchange -> {\n            exchange.getResponseHeaders().add(\"Location\", \"http://127.0.0.1:\" + portB + \"/target-308\");\n            exchange.sendResponseHeaders(308, -1);\n            exchange.close();\n        });\n\n        serverB.createContext(\"/target-308\", exchange -> {\n            authOn308Target.set(exchange.getRequestHeaders().getFirst(\"Authorization\"));\n            bodyOn308Target.set(new String(exchange.getRequestBody().readAllBytes(), StandardCharsets.UTF_8));\n            exchange.sendResponseHeaders(200, 0);\n            exchange.getResponseBody().close();\n            exchange.close();\n        });\n\n        serverA.start();\n        serverB.start();\n        serverC.start();\n    }\n\n    @AfterAll\n    public static void stopServers() {\n        serverA.stop(0);\n        serverB.stop(0);\n        serverC.stop(0);\n    }\n\n    /**\n     * Cross-domain redirect (different port) must strip Authorization header.\n     */\n    @Test\n    void crossDomainRedirectStripsAuthHeader() throws Exception {\n        DefaultAsyncHttpClientConfig config = new DefaultAsyncHttpClientConfig.Builder()\n                .setFollowRedirect(true)\n                .build();\n        try (DefaultAsyncHttpClient client = new DefaultAsyncHttpClient(config)) {\n            lastAuthHeaderOnA.set(null);\n            lastAuthHeaderOnB.set(null);\n\n            client.prepareGet(\"http://127.0.0.1:\" + portA + \"/redirect-to-b\")\n                    .setHeader(\"Authorization\", \"Bearer secret-token\")\n                    .execute()\n                    .get(5, TimeUnit.SECONDS);\n\n            // Auth header should be present on the original request to server A\n            assertEquals(\"Bearer secret-token\", lastAuthHeaderOnA.get(),\n                    \"Authorization header should be present on original request\");\n            // Auth header must NOT be forwarded to the cross-domain target (server B)\n            assertNull(lastAuthHeaderOnB.get(),\n                    \"Authorization header must be stripped on cross-domain redirect\");\n        }\n    }\n\n    /**\n     * Same-origin redirect (same host and port) should preserve Authorization header.\n     */\n    @Test\n    void sameOriginRedirectPreservesAuthHeader() throws Exception {\n        DefaultAsyncHttpClientConfig config = new DefaultAsyncHttpClientConfig.Builder()\n                .setFollowRedirect(true)\n                .build();\n        try (DefaultAsyncHttpClient client = new DefaultAsyncHttpClient(config)) {\n            lastAuthHeaderOnA.set(null);\n\n            client.prepareGet(\"http://127.0.0.1:\" + portA + \"/redirect-same-origin\")\n                    .setHeader(\"Authorization\", \"Bearer secret-token\")\n                    .execute()\n                    .get(5, TimeUnit.SECONDS);\n\n            // Auth header should still be present after same-origin redirect\n            assertEquals(\"Bearer secret-token\", lastAuthHeaderOnA.get(),\n                    \"Authorization header should be preserved on same-origin redirect\");\n        }\n    }\n\n    /**\n     * Cross-domain redirect must strip Proxy-Authorization header too.\n     */\n    @Test\n    void crossDomainRedirectStripsProxyAuthHeader() throws Exception {\n        DefaultAsyncHttpClientConfig config = new DefaultAsyncHttpClientConfig.Builder()\n                .setFollowRedirect(true)\n                .build();\n        try (DefaultAsyncHttpClient client = new DefaultAsyncHttpClient(config)) {\n            lastAuthHeaderOnB.set(null);\n\n            // We capture Proxy-Authorization on server B using a custom handler\n            final AtomicReference<String> proxyAuthOnB = new AtomicReference<>();\n            serverB.createContext(\"/target-proxy\", exchange -> {\n                proxyAuthOnB.set(exchange.getRequestHeaders().getFirst(\"Proxy-Authorization\"));\n                exchange.sendResponseHeaders(200, 0);\n                exchange.getResponseBody().close();\n                exchange.close();\n            });\n            serverA.createContext(\"/redirect-to-b-proxy\", exchange -> {\n                exchange.getResponseHeaders().add(\"Location\", \"http://127.0.0.1:\" + portB + \"/target-proxy\");\n                exchange.sendResponseHeaders(302, -1);\n                exchange.close();\n            });\n\n            client.prepareGet(\"http://127.0.0.1:\" + portA + \"/redirect-to-b-proxy\")\n                    .setHeader(\"Proxy-Authorization\", \"Basic cHJveHk6cGFzcw==\")\n                    .execute()\n                    .get(5, TimeUnit.SECONDS);\n\n            assertNull(proxyAuthOnB.get(),\n                    \"Proxy-Authorization header must be stripped on cross-domain redirect\");\n        }\n    }\n\n    /**\n     * Realm-based BASIC auth credentials must NOT be propagated on cross-domain redirects.\n     * This tests that the Realm object is cleared, preventing credential regeneration\n     * via NettyRequestFactory.\n     */\n    @Test\n    void crossDomainRedirectDoesNotPropagateRealm() throws Exception {\n        DefaultAsyncHttpClientConfig config = new DefaultAsyncHttpClientConfig.Builder()\n                .setFollowRedirect(true)\n                .build();\n        try (DefaultAsyncHttpClient client = new DefaultAsyncHttpClient(config)) {\n            lastAuthHeaderOnB.set(null);\n\n            client.prepareGet(\"http://127.0.0.1:\" + portA + \"/redirect-to-b\")\n                    .setRealm(basicAuthRealm(\"user\", \"password\").setUsePreemptiveAuth(true).build())\n                    .execute()\n                    .get(5, TimeUnit.SECONDS);\n\n            // The Realm-generated Authorization header must NOT appear on the cross-domain target\n            assertNull(lastAuthHeaderOnB.get(),\n                    \"Realm-based credentials must not be propagated on cross-domain redirect\");\n        }\n    }\n\n    /**\n     * Realm bypass is closed: even with stripAuthorizationOnRedirect=true on a same-origin redirect,\n     * the Realm credential regeneration must be prevented (no Authorization header on target).\n     */\n    @Test\n    void stripAuthorizationOnRedirectAlsoStripsRealm() throws Exception {\n        DefaultAsyncHttpClientConfig config = new DefaultAsyncHttpClientConfig.Builder()\n                .setFollowRedirect(true)\n                .setStripAuthorizationOnRedirect(true)\n                .build();\n        try (DefaultAsyncHttpClient client = new DefaultAsyncHttpClient(config)) {\n            lastAuthHeaderOnA.set(null);\n\n            client.prepareGet(\"http://127.0.0.1:\" + portA + \"/redirect-same-origin\")\n                    .setRealm(basicAuthRealm(\"user\", \"password\").setUsePreemptiveAuth(true).build())\n                    .execute()\n                    .get(5, TimeUnit.SECONDS);\n\n            // Even on same-origin, with stripAuthorizationOnRedirect=true, the Realm-regenerated\n            // Authorization header must NOT appear (this was the bypass bug)\n            assertNull(lastAuthHeaderOnA.get(),\n                    \"stripAuthorizationOnRedirect=true must also prevent Realm-based credential regeneration\");\n        }\n    }\n\n    /**\n     * Same-origin redirect should preserve Realm-based credentials when stripping is not enabled.\n     */\n    @Test\n    void sameOriginRedirectPreservesRealmCredentials() throws Exception {\n        DefaultAsyncHttpClientConfig config = new DefaultAsyncHttpClientConfig.Builder()\n                .setFollowRedirect(true)\n                .build();\n        try (DefaultAsyncHttpClient client = new DefaultAsyncHttpClient(config)) {\n            lastAuthHeaderOnA.set(null);\n\n            client.prepareGet(\"http://127.0.0.1:\" + portA + \"/redirect-same-origin\")\n                    .setRealm(basicAuthRealm(\"user\", \"password\").setUsePreemptiveAuth(true).build())\n                    .execute()\n                    .get(5, TimeUnit.SECONDS);\n\n            // On same-origin, Realm credentials should be preserved\n            assertEquals(\"Basic dXNlcjpwYXNzd29yZA==\", lastAuthHeaderOnA.get(),\n                    \"Realm-based credentials should be preserved on same-origin redirect\");\n        }\n    }\n\n    /**\n     * Multi-hop redirect: A → A (same-origin) → B (cross-domain).\n     * Credentials should survive the same-origin hop but be stripped on the cross-domain hop.\n     */\n    @Test\n    void multiHopSameOriginThenCrossDomainStripsCredentials() throws Exception {\n        DefaultAsyncHttpClientConfig config = new DefaultAsyncHttpClientConfig.Builder()\n                .setFollowRedirect(true)\n                .build();\n        try (DefaultAsyncHttpClient client = new DefaultAsyncHttpClient(config)) {\n            authAtChainStep2.set(null);\n            lastAuthHeaderOnB.set(null);\n\n            client.prepareGet(\"http://127.0.0.1:\" + portA + \"/chain-same-then-cross\")\n                    .setHeader(\"Authorization\", \"Bearer secret-token\")\n                    .execute()\n                    .get(5, TimeUnit.SECONDS);\n\n            // Credentials should survive the same-origin intermediate hop (A → A)\n            assertEquals(\"Bearer secret-token\", authAtChainStep2.get(),\n                    \"Authorization header should be preserved on same-origin intermediate redirect\");\n            // Credentials must be stripped on the final cross-domain hop (A → B)\n            assertNull(lastAuthHeaderOnB.get(),\n                    \"Authorization header must be stripped on cross-domain hop in redirect chain\");\n        }\n    }\n\n    /**\n     * Multi-hop redirect: A → B (cross-domain) → C (another domain).\n     * Once credentials are stripped at the first cross-domain hop, they must not reappear\n     * on subsequent hops even if the Realm was originally set.\n     */\n    @Test\n    void multiHopCredentialsStayStrippedAfterCrossDomain() throws Exception {\n        DefaultAsyncHttpClientConfig config = new DefaultAsyncHttpClientConfig.Builder()\n                .setFollowRedirect(true)\n                .build();\n        try (DefaultAsyncHttpClient client = new DefaultAsyncHttpClient(config)) {\n            authOnBounceBack.set(null);\n\n            client.prepareGet(\"http://127.0.0.1:\" + portA + \"/chain-cross-and-back\")\n                    .setRealm(basicAuthRealm(\"user\", \"password\").setUsePreemptiveAuth(true).build())\n                    .execute()\n                    .get(5, TimeUnit.SECONDS);\n\n            // Credentials were stripped at A → B; they must not reappear at B → C\n            assertNull(authOnBounceBack.get(),\n                    \"Credentials must not reappear after being stripped at a cross-domain hop\");\n        }\n    }\n\n    /**\n     * 307 Temporary Redirect cross-domain: body is preserved but Authorization is stripped.\n     */\n    @Test\n    void redirect307CrossDomainStripsAuthButPreservesBody() throws Exception {\n        DefaultAsyncHttpClientConfig config = new DefaultAsyncHttpClientConfig.Builder()\n                .setFollowRedirect(true)\n                .build();\n        try (DefaultAsyncHttpClient client = new DefaultAsyncHttpClient(config)) {\n            authOn307Target.set(null);\n            bodyOn307Target.set(null);\n\n            client.preparePost(\"http://127.0.0.1:\" + portA + \"/redirect-307-to-b\")\n                    .setHeader(\"Authorization\", \"Bearer secret-token\")\n                    .setBody(\"request-body-content\")\n                    .execute()\n                    .get(5, TimeUnit.SECONDS);\n\n            assertNull(authOn307Target.get(),\n                    \"Authorization header must be stripped on cross-domain 307 redirect\");\n            assertEquals(\"request-body-content\", bodyOn307Target.get(),\n                    \"Request body must be preserved on 307 redirect\");\n        }\n    }\n\n    /**\n     * 308 Permanent Redirect cross-domain: body is preserved but Authorization is stripped.\n     */\n    @Test\n    void redirect308CrossDomainStripsAuthButPreservesBody() throws Exception {\n        DefaultAsyncHttpClientConfig config = new DefaultAsyncHttpClientConfig.Builder()\n                .setFollowRedirect(true)\n                .build();\n        try (DefaultAsyncHttpClient client = new DefaultAsyncHttpClient(config)) {\n            authOn308Target.set(null);\n            bodyOn308Target.set(null);\n\n            client.preparePost(\"http://127.0.0.1:\" + portA + \"/redirect-308-to-b\")\n                    .setHeader(\"Authorization\", \"Bearer secret-token\")\n                    .setBody(\"request-body-content\")\n                    .execute()\n                    .get(5, TimeUnit.SECONDS);\n\n            assertNull(authOn308Target.get(),\n                    \"Authorization header must be stripped on cross-domain 308 redirect\");\n            assertEquals(\"request-body-content\", bodyOn308Target.get(),\n                    \"Request body must be preserved on 308 redirect\");\n        }\n    }\n}\n","numLines":428,"startLine":1,"totalLines":428}}}
