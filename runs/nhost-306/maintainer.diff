-	i := 0
-	for _, s := range elems {
-		if _, exists := m[s]; exists {
-			continue
-		}
-		m[s] = i
-		i++
-		maxLen = max(maxLen, len(s))
-	}
-	return SortedSet{
-		m:      m,
-		maxLen: maxLen,
-	}
-}
